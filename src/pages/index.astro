---
import Layout from '../layouts/Layout.astro';
import Hero from '../components/Hero.astro';
import ReleaseFeature from '../components/ReleaseFeature.astro';
import Footer from '../components/Footer.astro';
---

<Layout title="VEILBURNER - Unofficial Fan Site">
  <Hero />
  <div class="home-release">
    <ReleaseFeature />
  </div>
  <Footer />
</Layout>

<style>
  /* Rough-in: give the release feature a solid black stage on mobile */
  @media (max-width: 768px) {
    .home-release {
      background: #000;
      min-height: 33vh;
      display: flex;
      align-items: center;
    }
  }
</style>
