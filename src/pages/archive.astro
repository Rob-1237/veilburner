---
import Layout from '../layouts/Layout.astro';
import Footer from '../components/Footer.astro';
import { reviews } from '../data/reviews.js';
import { interviewsWritten } from '../data/interviews-written.js';
import { interviews } from '../data/interviews.js';
import { media } from '../data/media.js';
---

<Layout title="VEILBURNER - Archive">
  <div class="vb-logo-gradient">
    <a href="/" aria-label="Home">
      <img src="/images/logo-vb-white-no-bg.png" alt="Veilburner logo" />
    </a>
  </div>
  <h1 class="archive-page__title">ARCHIVE</h1>
  <section class="archive-page">
    <div class="container">

      <!-- 1. Interviews (Written) Section -->
      <section class="archive-section collapsed" data-section="interviews">
        <div class="archive-section__header">
          <h2 class="archive-section__title">INTERVIEWS</h2>
          <button class="archive-section__toggle" aria-label="Toggle Interviews section">
            <span class="section-toggle-icon">🜃</span>
          </button>
        </div>
        <div class="archive-section__content-wrapper">
          <div class="archive-section__content">
            {interviewsWritten.map((interview, index) => (
            <div class="review-card" data-item-id={index}>
              <div class="review-card__content">
                <blockquote class="review-card__quote">"{interview.quote}"</blockquote>
                <div class="review-card__attribution">
                  <span>— {interview.publication}, {interview.date}</span>
                  <button class="review-card__toggle" aria-label="Expand interview">
                    <span class="toggle-icon">🜁</span>
                  </button>
                </div>
                <div class="review-card__expandable">
                  <div class="review-card__expandable-content">
                    <div class="review-card__full-text">
                      <p>{interview.fullText}</p>
                    </div>
                    {interview.link && (
                      <a href={interview.link} target="_blank" rel="noopener noreferrer" class="review-card__link">
                        Read Full Interview →
                      </a>
                    )}
                  </div>
                </div>
              </div>
            </div>
          ))}
          </div>
        </div>
      </section>

      <!-- 2. Reviews (Written) Section -->
      <section class="archive-section collapsed" data-section="reviews">
        <div class="archive-section__header">
          <h2 class="archive-section__title">ALBUM REVIEWS</h2>
          <button class="archive-section__toggle" aria-label="Toggle Reviews section">
            <span class="section-toggle-icon">🜃</span>
          </button>
        </div>
        <div class="archive-section__content-wrapper">
          <div class="archive-section__content">
            {reviews.map((review, index) => (
            <div class="review-card" data-item-id={index}>
              <div class="review-card__content">
                <blockquote class="review-card__quote">"{review.quote}"</blockquote>
                <div class="review-card__attribution">
                  <span>— {review.publication}, {review.date}<span class="review-author">&nbsp;{review.author}</span></span>
                  <button class="review-card__toggle" aria-label="Expand review">
                    <span class="toggle-icon">🜁</span>
                  </button>
                </div>
                <div class="review-card__expandable">
                  <div class="review-card__expandable-content">
                    <div class="review-card__full-text">
                      <p>{review.fullText}</p>
                      {review.album && (
                        <p class="review-card__meta"><strong>Album:</strong> {review.album}</p>
                      )}
                      {review.rating && (
                        <p class="review-card__meta"><strong>Rating:</strong> {review.rating}</p>
                      )}
                    </div>
                    {review.link && (
                      <a href={review.link} target="_blank" rel="noopener noreferrer" class="review-card__link">
                        Read Full Review →
                      </a>
                    )}
                  </div>
                </div>
              </div>
            </div>
          ))}
          </div>
        </div>
      </section>

      <!-- 4. Video Interviews Section -->
      <section class="archive-section collapsed" data-section="video-interviews">
        <div class="archive-section__header">
          <h2 class="archive-section__title">VIDEO INTERVIEWS</h2>
          <button class="archive-section__toggle" aria-label="Toggle Video Interviews section">
            <span class="section-toggle-icon">🜃</span>
          </button>
        </div>
        <div class="archive-section__content-wrapper">
          <div class="archive-section__content">
            <div class="media-grid">
              {interviews.map((video) => (
              <div class="media-embed">
                <h3 class="media-embed__title">{video.title}</h3>
                <div class="media-embed__wrapper">
                  <iframe
                    width="800"
                    height="450"
                    src={`https://www.youtube.com/embed/${video.videoId}?theme=dark&modestbranding=1&rel=0`}
                    frameborder="0"
                    allow="accelerometer; autoplay; clipboard-write; encrypted-media; gyroscope; picture-in-picture"
                    allowfullscreen
                  ></iframe>
                </div>
              </div>
            ))}
            </div>
          </div>
        </div>
      </section>

      <!-- 5. Video Reviews Section -->
      <section class="archive-section collapsed" data-section="video-reviews">
        <div class="archive-section__header">
          <h2 class="archive-section__title">VIDEO REVIEWS</h2>
          <button class="archive-section__toggle" aria-label="Toggle Video Reviews section">
            <span class="section-toggle-icon">🜃</span>
          </button>
        </div>
        <div class="archive-section__content-wrapper">
          <div class="archive-section__content">
            <div class="media-grid">
              {media.videoReviews.map((video) => (
              <div class="media-embed">
                <h3 class="media-embed__title">{video.title}</h3>
                <div class="media-embed__wrapper">
                  <iframe
                    width="800"
                    height="450"
                    src={`https://www.youtube.com/embed/${video.videoId}?theme=dark&modestbranding=1&rel=0`}
                    frameborder="0"
                    allow="accelerometer; autoplay; clipboard-write; encrypted-media; gyroscope; picture-in-picture"
                    allowfullscreen
                  ></iframe>
                </div>
              </div>
            ))}
            </div>
          </div>
        </div>
      </section>

      <!-- 6. Video Misc Section -->
      <section class="archive-section collapsed" data-section="video-misc">
        <div class="archive-section__header">
          <h2 class="archive-section__title">VIDEO MISC</h2>
          <button class="archive-section__toggle" aria-label="Toggle Video Misc section">
            <span class="section-toggle-icon">🜃</span>
          </button>
        </div>
        <div class="archive-section__content-wrapper">
          <div class="archive-section__content">
            <div class="media-grid">
              {media.videoMisc.map((video) => (
              <div class="media-embed">
                <h3 class="media-embed__title">{video.title}</h3>
                <div class="media-embed__wrapper">
                  <iframe
                    width="800"
                    height="450"
                    src={`https://www.youtube.com/embed/${video.videoId}?theme=dark&modestbranding=1&rel=0`}
                    frameborder="0"
                    allow="accelerometer; autoplay; clipboard-write; encrypted-media; gyroscope; picture-in-picture"
                    allowfullscreen
                  ></iframe>
                </div>
              </div>
            ))}
            </div>
          </div>
        </div>
      </section>

      <!-- 7. Reels Section -->
      <section class="archive-section collapsed" data-section="reels">
        <div class="archive-section__header">
          <h2 class="archive-section__title">REELS</h2>
          <button class="archive-section__toggle" aria-label="Toggle Reels section">
            <span class="section-toggle-icon">🜃</span>
          </button>
        </div>
        <div class="archive-section__content-wrapper">
          <div class="archive-section__content">
            <div class="reels-grid">
              {media.reels.map((reel) => (
              <div class="reel-container">
                <h3 class="reel-container__title">{reel.title}</h3>
                <div class="reel-container__wrapper">
                  <video
                    class="reel-video"
                    controls
                    playsinline
                    preload="metadata"
                    poster=""
                  >
                    <source src={reel.videoSrc} type="video/mp4" />
                    Your browser does not support the video tag.
                  </video>
                </div>
                {reel.link && (
                  <a href={reel.link} target="_blank" rel="noopener noreferrer" class="reel-container__link">
                    View Original →
                  </a>
                )}
              </div>
            ))}
            </div>
          </div>
        </div>
      </section>
    </div>
  </section>
  <Footer />
</Layout>

<style lang="scss">
  @import '../styles/global.scss';

  .archive-page {
    padding: 4.5rem 1.125rem 2.25rem;
    min-height: 100vh;

    &__title {
      font-family: $font-metal;
      color: #5a3a2a;
      font-size: 2.25rem;
      text-align: center;
      padding-top: 6rem;
      text-transform: uppercase;
      letter-spacing: 0.15em;
      font-weight: 300;

      @media (max-width: 768px) {
        font-size: 2.25rem;
      }
    }
  }

  .archive-section {
    margin-bottom: 4.5rem;

    &__header {
      display: flex;
      justify-content: space-between;
      align-items: center;
      margin-bottom: 1.5rem;
      cursor: pointer;
      user-select: none;

      &:hover .archive-section__title {
        color: #5a3a2a; // Rust on hover
      }
    }

    &__title {
      font-family: $font-body;
      font-size: 1.25rem;
      margin-bottom: 0;
      text-transform: uppercase;
      letter-spacing: 0.15em;
      font-weight: 300;
      color: #8b7355; // Bone
      transition: color 0.3s ease;

      @media (max-width: 768px) {
        font-size: 1.25rem;
      }
    }

    &__toggle {
      background: none;
      border: none;
      color: #8b7355; // Bone
      font-size: 1.5rem;
      cursor: pointer;
      padding: 0;
      width: 30px;
      height: 30px;
      display: flex;
      align-items: center;
      justify-content: center;
      transition: color 0.3s ease;
      flex-shrink: 0;

      &:hover {
        color: #5a3a2a; // Rust
      }

      @media (max-width: 768px) {
        width: 26.25px;
        height: 26.25px;
        font-size: 1.3125rem;
      }
    }

    .section-toggle-icon {
      display: inline-block;
      position: relative;
      transition: transform 0.3s ease;
    }

    &__toggle:hover .section-toggle-icon {
      transform: rotate(180deg);
    }

    // When collapsed, hide the HTML content and show plus via ::before
    &.collapsed .section-toggle-icon {
      font-size: 0; // Hide the HTML "−"

      &::before {
        content: '🜁';
        font-size: 1.5rem;
        position: absolute;
        top: 50%;
        left: 50%;
        transform: translate(-50%, -50%);

        @media (max-width: 768px) {
          font-size: 1.3125rem;
        }
      }
    }

    &__content-wrapper {
      display: grid;
      grid-template-rows: 1fr;
      transition: grid-template-rows 0.4s ease;
    }

    &.collapsed &__content-wrapper {
      grid-template-rows: 0fr;
    }

    &__content {
      max-width: 675px;
      margin: 0 auto;
      overflow: hidden;
    }
  }

  // Review Cards (Accordion)
  .review-card {
    margin-bottom: 1.5rem;
    cursor: pointer;
    transition: transform 0.3s ease;

    &:hover {
      transform: translateX(3px);
    }

    &__content {
      padding: 1.5rem;
      border: 1.5px solid #5a3a2a; // Rust
      border-left: 4.5px solid #5a3a2a;
      clip-path: polygon(0 0, 100% 0, 100% calc(100% - 9px), calc(100% - 9px) 100%, 0 100%);
      background: linear-gradient(90deg, rgba(139, 0, 0, 0.05) 0%, transparent 100%);
      transition: all 0.4s ease;
    }

    &.expanded &__content {
      border-color: #8b7355; // Bone
      box-shadow: -3px 0 0 #5a3a2a;
    }

    &__quote {
      font-family: 'IBM Plex Mono', monospace;
      font-size: 0.75rem;
      line-height: 1.6;
      color: #cccccc;
      margin: 0 0 1.125rem 0;
      font-style: italic;
    }

    &__expandable {
      display: grid;
      grid-template-rows: 0fr;
      transition: grid-template-rows 0.4s ease;
    }

    &.expanded &__expandable {
      grid-template-rows: 1fr;
    }

    &__expandable-content {
      overflow: hidden;
    }

    &__full-text {
      font-family: 'IBM Plex Mono', monospace;
      font-size: 0.7125rem;
      line-height: 1.7;
      color: #cccccc;
      margin-bottom: 1.125rem;
      margin-top: 1.125rem;

      p {
        margin-bottom: 0.75rem;
      }
    }

    &__meta {
      font-family: 'IBM Plex Mono', monospace;
      font-size: 0.675rem;
      color: #8b7355; // Bone
      margin-bottom: 0.375rem;

      strong {
        color: #5a3a2a; // Rust
      }
    }

    &__attribution {
      display: flex;
      justify-content: space-between;
      align-items: center;
      font-size: 0.6375rem;
      color: #666666;
      text-transform: uppercase;
      letter-spacing: 0.1em;
    }

    &__toggle {
      background: none;
      border: none;
      color: #8b7355; // Bone
      font-size: 1.125rem;
      cursor: pointer;
      padding: 0;
      width: 22.5px;
      height: 22.5px;
      display: flex;
      align-items: center;
      justify-content: center;
      transition: color 0.3s ease;

      &:hover {
        color: #5a3a2a; // Rust
      }
    }

    .toggle-icon {
      display: inline-block;
      position: relative;
      transition: transform 0.3s ease;
    }

    &__toggle:hover .toggle-icon {
      transform: rotate(180deg);
    }

    // When expanded, hide the HTML content and show minus via ::before
    &.expanded .toggle-icon {
      font-size: 0; // Hide the HTML "+"

      &::before {
        content: '🜃';
        font-size: 1.125rem;
        position: absolute;
        top: 50%;
        left: 50%;
        transform: translate(-50%, -50%);
      }
    }

    &__link {
      display: inline-block;
      margin-top: 0.75rem;
      font-family: 'IBM Plex Mono', monospace;
      color: #5a3a2a; // Rust
      text-decoration: none;
      font-size: 0.675rem;
      transition: color 0.3s ease;

      &:hover {
        color: #8b7355; // Bone
      }
    }
  }

  .review-author {
    font-size: .6rem;
    font-style: italic;
    color: #5a3a2a;
    text-align: left;
    text-transform: lowercase;
  }

  // Media Grid
  .media-grid {
    display: grid;
    grid-template-columns: 1fr;
    gap: 2.25rem;

    @media (min-width: 768px) {
      grid-template-columns: repeat(2, 1fr);
      gap: 1.5rem;
    }
  }

  // Media Embeds
  .media-embed {
    display: flex;
    flex-direction: column;

    &__title {
      font-family: 'Inter', sans-serif;
      font-size: 0.675rem;
      color: #666666; // Bone
      margin-bottom: 0.75rem;
      text-transform: uppercase;
      letter-spacing: 0.1em;
      line-height: 1.4;
      min-height: 2.25em; // Reserve space for ~3 lines of text
      display: flex;
      align-items: flex-start;
      font-weight: 300;

      @media (min-width: 768px) {
        font-size: 0.6375rem;
        min-height: 3.1875em; // Adjusted for smaller font
      }
    }

    &__wrapper {
      position: relative;
      width: 100%;
      border: 2.25px solid #5a3a2a; // Rust
      clip-path: polygon(9px 0, 100% 0, 100% calc(100% - 9px), calc(100% - 9px) 100%, 0 100%, 0 9px);
      overflow: hidden;

      iframe {
        display: block;
        width: 100%;
        height: 225px;

        @media (min-width: 768px) {
          height: 187.5px;
        }

        @media (min-width: 1024px) {
          height: 225px;
        }
      }
    }
  }

  // Reels Grid (Vertical Video Players)
  .reels-grid {
    display: grid;
    grid-template-columns: 1fr;
    gap: 2.25rem;
    max-width: 525px;
    margin: 0 auto;

    @media (min-width: 768px) {
      grid-template-columns: repeat(2, 1fr);
      gap: 1.5rem;
    }
  }

  .reel-container {
    display: flex;
    flex-direction: column;
    align-items: center;

    &__title {
      font-family: 'Oswald', sans-serif;
      font-size: 0.6375rem;
      color: #666666; // Bone
      margin-bottom: 0.75rem;
      text-transform: uppercase;
      letter-spacing: 0.1em;
      line-height: 1.4;
      text-align: center;
      font-weight: 300;

      @media (min-width: 768px) {
        font-size: 0.6rem;
      }
    }

    &__wrapper {
      position: relative;
      width: 100%;
      max-width: 240px; // Mobile-friendly width
      aspect-ratio: 9 / 16; // Vertical short/reel format
      border: 2.25px solid #5a3a2a; // Rust
      clip-path: polygon(9px 0, 100% 0, 100% calc(100% - 9px), calc(100% - 9px) 100%, 0 100%, 0 9px);
      overflow: hidden;
      background: #000;

      @media (max-width: 767px) {
        max-width: 210px;
      }
    }

    &__link {
      display: inline-block;
      margin-top: 0.75rem;
      font-family: 'Oswald', sans-serif;
      color: #5a3a2a; // Rust
      text-decoration: none;
      font-size: 0.6375rem;
      transition: color 0.3s ease;

      &:hover {
        color: #8b7355; // Bone
      }
    }
  }

  .reel-video {
    width: 100%;
    height: 100%;
    object-fit: cover; // Fill the container while maintaining aspect ratio
    display: block;
  }

  .vb-logo-gradient {
    position: fixed;
    top: 2rem;
    left: 2rem;
    width: 175px;
    height: 175px;
    z-index: 10000;

    @media (max-width: 768px) {
      top: 1rem;
      left: 1rem;
      width: 100px;
      height: 100px;
    }

    a {
      pointer-events: auto;
      display: block;
      width: 100%;
      height: 100%;
    }

    &::before {
      content: '';
      position: absolute;
      top: 0;
      left: 0;
      width: 100%;
      height: 100%;
      background: radial-gradient(circle at 50% 50%, rgb(125, 125, 125, .6), rgb(139, 0, 0, .4), rgb(56, 91, 56, .6), rgb(90, 58, 42, .6));
      // background: radial-gradient(circle at 50% 50%, rgb(25, 25, 25, .75), rgb(139, 0, 0, .4), rgb(90, 58, 42, .4));
      background-size: 200% 200%;
      animation: vb-logo-gradient 32s ease infinite;
      mask-image: url('/images/logo-vb-white-no-bg.png');
      mask-size: contain;
      mask-repeat: no-repeat;
      mask-position: center;
    }

    img {
      opacity: 0;
      width: 100%;
      height: 100%;
      object-fit: contain;
    }
  }

  @keyframes vb-logo-gradient {
    0% {
      background-position: 0% 50%;
    }
    50% {
      background-position: 100% 50%;
    }
    100% {
      background-position: 0% 50%;
    }
  }
</style>

<script>
  // Accordion behavior for all expandable cards
  function initAccordion() {
    const cards = document.querySelectorAll('.review-card');

    cards.forEach(card => {
      card.addEventListener('click', (e) => {
        // Don't toggle if clicking on the link
        if (e.target.closest('.review-card__link')) return;

        const isExpanded = card.classList.contains('expanded');

        // Close all other cards (accordion behavior)
        cards.forEach(otherCard => {
          if (otherCard !== card) {
            otherCard.classList.remove('expanded');
          }
        });

        // Toggle current card
        if (isExpanded) {
          card.classList.remove('expanded');
        } else {
          card.classList.add('expanded');
        }
      });
    });
  }

  // Initialize on page load and after transitions
  document.addEventListener('astro:page-load', initAccordion);

  // Section accordion behavior (separate from review card accordions)
  function initSectionAccordion() {
    const sections = document.querySelectorAll('.archive-section');

    sections.forEach(section => {
      const header = section.querySelector('.archive-section__header');
      const toggle = section.querySelector('.archive-section__toggle');

      if (header && toggle) {
        // Click on header or toggle button
        const handleToggle = (e) => {
          e.stopPropagation(); // Prevent event bubbling
          section.classList.toggle('collapsed');
        };

        header.addEventListener('click', handleToggle);
      }
    });
  }

  // Initialize section accordions on page load and after transitions
  document.addEventListener('astro:page-load', initSectionAccordion);
</script>
