---
import NavigationLayout from '../layouts/NavigationLayout.astro';
import { reviews } from '../data/reviews.js';
import { interviewsWritten } from '../data/interviews-written.js';
import { interviews } from '../data/interviews.js';
import { news } from '../data/news.js';
import { media } from '../data/media.js';
---

<NavigationLayout title="VEILBURNER - Archive">
  <section class="archive-page">
    <div class="container">
      <h1 class="archive-page__title">ARCHIVE</h1>

      <!-- 1. Interviews (Written) Section -->
      <section class="archive-section">
        <h2 class="archive-section__title">INTERVIEWS</h2>
        <div class="archive-section__content">
          {interviewsWritten.map((interview, index) => (
            <div class="review-card" data-item-id={index}>
              <div class="review-card__content">
                <blockquote class="review-card__quote">"{interview.quote}"</blockquote>
                <div class="review-card__full-text" style="display: none;">
                  <p>{interview.fullText}</p>
                </div>
                <div class="review-card__attribution">
                  <span>— {interview.publication}, {interview.date}</span>
                  <button class="review-card__toggle" aria-label="Expand interview">
                    <span class="toggle-icon">+</span>
                  </button>
                </div>
                {interview.link && (
                  <a href={interview.link} target="_blank" rel="noopener noreferrer" class="review-card__link" style="display: none;">
                    Read Full Interview →
                  </a>
                )}
              </div>
            </div>
          ))}
        </div>
      </section>

      <!-- 2. Reviews (Written) Section -->
      <section class="archive-section">
        <h2 class="archive-section__title">REVIEWS</h2>
        <div class="archive-section__content">
          {reviews.map((review, index) => (
            <div class="review-card" data-item-id={index}>
              <div class="review-card__content">
                <blockquote class="review-card__quote">"{review.quote}"</blockquote>
                <div class="review-card__full-text" style="display: none;">
                  <p>{review.fullText}</p>
                  {review.album && (
                    <p class="review-card__meta"><strong>Album:</strong> {review.album}</p>
                  )}
                  {review.rating && (
                    <p class="review-card__meta"><strong>Rating:</strong> {review.rating}</p>
                  )}
                </div>
                <div class="review-card__attribution">
                  <span>— {review.publication}, {review.date}</span>
                  <button class="review-card__toggle" aria-label="Expand review">
                    <span class="toggle-icon">+</span>
                  </button>
                </div>
                {review.link && (
                  <a href={review.link} target="_blank" rel="noopener noreferrer" class="review-card__link" style="display: none;">
                    Read Full Review →
                  </a>
                )}
              </div>
            </div>
          ))}
        </div>
      </section>

      <!-- 3. News Section -->
      <section class="archive-section">
        <h2 class="archive-section__title">NEWS</h2>
        <div class="archive-section__content">
          {news.map((item, index) => (
            <div class="review-card" data-item-id={index}>
              <div class="review-card__content">
                <blockquote class="review-card__quote">"{item.quote}"</blockquote>
                <div class="review-card__full-text" style="display: none;">
                  <p>{item.fullText}</p>
                </div>
                <div class="review-card__attribution">
                  <span>— {item.publication}, {item.date}</span>
                  <button class="review-card__toggle" aria-label="Expand news item">
                    <span class="toggle-icon">+</span>
                  </button>
                </div>
                {item.link && (
                  <a href={item.link} target="_blank" rel="noopener noreferrer" class="review-card__link" style="display: none;">
                    Read More →
                  </a>
                )}
              </div>
            </div>
          ))}
        </div>
      </section>

      <!-- 4. Video Interviews Section -->
      <section class="archive-section">
        <h2 class="archive-section__title">VIDEO INTERVIEWS</h2>
        <div class="archive-section__content">
          <div class="media-grid">
            {interviews.map((video) => (
              <div class="media-embed">
                <h3 class="media-embed__title">{video.title}</h3>
                <div class="media-embed__wrapper">
                  <iframe
                    width="800"
                    height="450"
                    src={`https://www.youtube.com/embed/${video.videoId}?theme=dark&modestbranding=1&rel=0`}
                    frameborder="0"
                    allow="accelerometer; autoplay; clipboard-write; encrypted-media; gyroscope; picture-in-picture"
                    allowfullscreen
                  ></iframe>
                </div>
              </div>
            ))}
          </div>
        </div>
      </section>

      <!-- 5. Video Reviews Section -->
      <section class="archive-section">
        <h2 class="archive-section__title">VIDEO REVIEWS</h2>
        <div class="archive-section__content">
          <div class="media-grid">
            {media.videoReviews.map((video) => (
              <div class="media-embed">
                <h3 class="media-embed__title">{video.title}</h3>
                <div class="media-embed__wrapper">
                  <iframe
                    width="800"
                    height="450"
                    src={`https://www.youtube.com/embed/${video.videoId}?theme=dark&modestbranding=1&rel=0`}
                    frameborder="0"
                    allow="accelerometer; autoplay; clipboard-write; encrypted-media; gyroscope; picture-in-picture"
                    allowfullscreen
                  ></iframe>
                </div>
              </div>
            ))}
          </div>
        </div>
      </section>

      <!-- 6. Video Misc Section -->
      <section class="archive-section">
        <h2 class="archive-section__title">VIDEO MISC</h2>
        <div class="archive-section__content">
          <div class="media-grid">
            {media.videoMisc.map((video) => (
              <div class="media-embed">
                <h3 class="media-embed__title">{video.title}</h3>
                <div class="media-embed__wrapper">
                  <iframe
                    width="800"
                    height="450"
                    src={`https://www.youtube.com/embed/${video.videoId}?theme=dark&modestbranding=1&rel=0`}
                    frameborder="0"
                    allow="accelerometer; autoplay; clipboard-write; encrypted-media; gyroscope; picture-in-picture"
                    allowfullscreen
                  ></iframe>
                </div>
              </div>
            ))}
          </div>
        </div>
      </section>

      <!-- 7. Reels Section -->
      <section class="archive-section">
        <h2 class="archive-section__title">REELS</h2>
        <div class="archive-section__content">
          <div class="reels-grid">
            {media.reels.map((reel) => (
              <div class="reel-container">
                <h3 class="reel-container__title">{reel.title}</h3>
                <div class="reel-container__wrapper">
                  <video
                    class="reel-video"
                    controls
                    playsinline
                    preload="metadata"
                    poster=""
                  >
                    <source src={reel.videoSrc} type="video/mp4" />
                    Your browser does not support the video tag.
                  </video>
                </div>
                {reel.link && (
                  <a href={reel.link} target="_blank" rel="noopener noreferrer" class="reel-container__link">
                    View Original →
                  </a>
                )}
              </div>
            ))}
          </div>
        </div>
      </section>
    </div>
  </section>
</NavigationLayout>

<style lang="scss">
  .archive-page {
    padding: 6rem 1.5rem 3rem;
    min-height: 100vh;

    &__title {
      font-family: 'Oswald', sans-serif;
      font-size: 4rem;
      text-align: center;
      margin-bottom: 4rem;
      text-transform: uppercase;
      letter-spacing: 0.15em;
      font-weight: 700;

      @media (max-width: 768px) {
        font-size: 3rem;
      }
    }
  }

  .archive-section {
    margin-bottom: 6rem;

    &__title {
      font-family: 'Oswald', sans-serif;
      font-size: 2.5rem;
      margin-bottom: 2rem;
      text-transform: uppercase;
      letter-spacing: 0.15em;
      font-weight: 700;
      color: #8b7355; // Bone

      @media (max-width: 768px) {
        font-size: 2rem;
      }
    }

    &__content {
      max-width: 900px;
      margin: 0 auto;
    }
  }

  // Review Cards (Accordion)
  .review-card {
    margin-bottom: 2rem;
    cursor: pointer;
    transition: transform 0.3s ease;

    &:hover {
      transform: translateX(4px);
    }

    &__content {
      padding: 2rem;
      border: 2px solid #5a3a2a; // Rust
      border-left: 6px solid #5a3a2a;
      clip-path: polygon(0 0, 100% 0, 100% calc(100% - 12px), calc(100% - 12px) 100%, 0 100%);
      background: linear-gradient(90deg, rgba(139, 0, 0, 0.05) 0%, transparent 100%);
      transition: all 0.4s ease;
    }

    &.expanded &__content {
      border-color: #8b7355; // Bone
      box-shadow: -4px 0 0 #5a3a2a;
    }

    &__quote {
      font-family: 'Courier New', monospace;
      font-size: 1rem;
      line-height: 1.6;
      color: #cccccc;
      margin: 0 0 1.5rem 0;
      font-style: italic;
    }

    &__full-text {
      font-family: 'Courier New', monospace;
      font-size: 0.95rem;
      line-height: 1.7;
      color: #cccccc;
      margin-bottom: 1.5rem;
      overflow: hidden;
      transition: max-height 0.4s ease;

      p {
        margin-bottom: 1rem;
      }
    }

    &__meta {
      font-family: 'Courier New', monospace;
      font-size: 0.9rem;
      color: #8b7355; // Bone
      margin-bottom: 0.5rem;

      strong {
        color: #5a3a2a; // Rust
      }
    }

    &__attribution {
      display: flex;
      justify-content: space-between;
      align-items: center;
      font-size: 0.85rem;
      color: #666666;
      text-transform: uppercase;
      letter-spacing: 0.1em;
    }

    &__toggle {
      background: none;
      border: none;
      color: #8b7355; // Bone
      font-size: 1.5rem;
      cursor: pointer;
      padding: 0;
      width: 30px;
      height: 30px;
      display: flex;
      align-items: center;
      justify-content: center;
      transition: transform 0.3s ease, color 0.3s ease;

      &:hover {
        color: #5a3a2a; // Rust
        transform: scale(1.2);
      }
    }

    &.expanded &__toggle .toggle-icon::before {
      content: '−';
    }

    &__link {
      display: inline-block;
      margin-top: 1rem;
      font-family: 'Courier New', monospace;
      color: #5a3a2a; // Rust
      text-decoration: none;
      font-size: 0.9rem;
      transition: color 0.3s ease;

      &:hover {
        color: #8b7355; // Bone
      }
    }
  }

  // Media Grid
  .media-grid {
    display: grid;
    grid-template-columns: 1fr;
    gap: 3rem;

    @media (min-width: 768px) {
      grid-template-columns: repeat(2, 1fr);
      gap: 2rem;
    }
  }

  // Media Embeds
  .media-embed {
    display: flex;
    flex-direction: column;

    &__title {
      font-family: 'Courier New', monospace;
      font-size: 0.9rem;
      color: #8b7355; // Bone
      margin-bottom: 1rem;
      text-transform: uppercase;
      letter-spacing: 0.05em;
      line-height: 1.4;
      min-height: 3em; // Reserve space for ~3 lines of text
      display: flex;
      align-items: flex-start;

      @media (min-width: 768px) {
        font-size: 0.85rem;
        min-height: 4.25em; // Adjusted for smaller font
      }
    }

    &__wrapper {
      position: relative;
      width: 100%;
      border: 3px solid #5a3a2a; // Rust
      clip-path: polygon(12px 0, 100% 0, 100% calc(100% - 12px), calc(100% - 12px) 100%, 0 100%, 0 12px);
      overflow: hidden;

      iframe {
        display: block;
        width: 100%;
        height: 300px;

        @media (min-width: 768px) {
          height: 250px;
        }

        @media (min-width: 1024px) {
          height: 300px;
        }
      }
    }
  }

  // Reels Grid (Vertical Video Players)
  .reels-grid {
    display: grid;
    grid-template-columns: 1fr;
    gap: 3rem;
    max-width: 700px;
    margin: 0 auto;

    @media (min-width: 768px) {
      grid-template-columns: repeat(2, 1fr);
      gap: 2rem;
    }
  }

  .reel-container {
    display: flex;
    flex-direction: column;
    align-items: center;

    &__title {
      font-family: 'Courier New', monospace;
      font-size: 0.85rem;
      color: #8b7355; // Bone
      margin-bottom: 1rem;
      text-transform: uppercase;
      letter-spacing: 0.05em;
      line-height: 1.4;
      text-align: center;

      @media (min-width: 768px) {
        font-size: 0.8rem;
      }
    }

    &__wrapper {
      position: relative;
      width: 100%;
      max-width: 320px; // Mobile-friendly width
      aspect-ratio: 9 / 16; // Vertical short/reel format
      border: 3px solid #5a3a2a; // Rust
      clip-path: polygon(12px 0, 100% 0, 100% calc(100% - 12px), calc(100% - 12px) 100%, 0 100%, 0 12px);
      overflow: hidden;
      background: #000;

      @media (max-width: 767px) {
        max-width: 280px;
      }
    }

    &__link {
      display: inline-block;
      margin-top: 1rem;
      font-family: 'Courier New', monospace;
      color: #5a3a2a; // Rust
      text-decoration: none;
      font-size: 0.85rem;
      transition: color 0.3s ease;

      &:hover {
        color: #8b7355; // Bone
      }
    }
  }

  .reel-video {
    width: 100%;
    height: 100%;
    object-fit: cover; // Fill the container while maintaining aspect ratio
    display: block;
  }
</style>

<script>
  // Accordion behavior for all expandable cards
  function initAccordion() {
    const cards = document.querySelectorAll('.review-card');

    cards.forEach(card => {
      card.addEventListener('click', (e) => {
        // Don't toggle if clicking on the link
        if (e.target.closest('.review-card__link')) return;

        const isExpanded = card.classList.contains('expanded');
        const fullText = card.querySelector('.review-card__full-text');
        const link = card.querySelector('.review-card__link');

        // Close all other cards (accordion behavior)
        cards.forEach(otherCard => {
          if (otherCard !== card) {
            otherCard.classList.remove('expanded');
            const otherFullText = otherCard.querySelector('.review-card__full-text');
            const otherLink = otherCard.querySelector('.review-card__link');
            if (otherFullText) otherFullText.style.display = 'none';
            if (otherLink) otherLink.style.display = 'none';
          }
        });

        // Toggle current card
        if (isExpanded) {
          card.classList.remove('expanded');
          if (fullText) fullText.style.display = 'none';
          if (link) link.style.display = 'none';
        } else {
          card.classList.add('expanded');
          if (fullText) fullText.style.display = 'block';
          if (link) link.style.display = 'inline-block';
        }
      });
    });
  }

  // Initialize on page load
  document.addEventListener('DOMContentLoaded', initAccordion);

  // Re-initialize after page transitions
  document.addEventListener('astro:after-swap', initAccordion);
</script>
