---
import { ViewTransitions } from "astro:transitions";
import Icon from "../components/Icon.astro";
import "../styles/fonts.css";

export interface Props {
  title: string;
  description?: string;
  ogImage?: string;
}

const {
  title,
  description = "Veilburner is a two-man avant-garde metal project from Pennsylvania, pushing the boundaries of extreme music since 2014.",
  ogImage = "/images/logo-entire-on-black.jpg"
} = Astro.props;
const currentPath = Astro.url.pathname;
const canonicalURL = `https://veilburner.band${currentPath}`;
// Use Astro.site for production builds, falls back to current origin in dev
const siteURL = Astro.site?.toString().replace(/\/$/, '') || Astro.url.origin;
const fullOgImageURL = `${siteURL}${ogImage}`;
const siteTitle = "VEILBURNER";

// Determine active page
const isHome = currentPath === "/";
const isAbout = currentPath.startsWith("/about");
const isListen = currentPath.startsWith("/listen");
const isArchive = currentPath.startsWith("/archive");

const bgImage = isListen
  ? "body__listen"
  : isArchive
    ? "body__archive"
    : "body__home";
---

<!doctype html>
<html lang="en">
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title>{title}</title>
    <meta name="description" content={description} />

    <!-- Canonical URL -->
    <link rel="canonical" href={canonicalURL} />

    <!-- Open Graph / Facebook -->
    <meta property="og:type" content="website" />
    <meta property="og:url" content={canonicalURL} />
    <meta property="og:title" content={title} />
    <meta property="og:description" content={description} />
    <meta property="og:image" content={fullOgImageURL} />
    <meta property="og:image:width" content="1200" />
    <meta property="og:image:height" content="630" />
    <meta property="og:site_name" content={siteTitle} />

    <!-- Twitter Card -->
    <meta name="twitter:card" content="summary_large_image" />
    <meta name="twitter:url" content={canonicalURL} />
    <meta name="twitter:title" content={title} />
    <meta name="twitter:description" content={description} />
    <meta name="twitter:image" content={fullOgImageURL} />

    <!-- Standard favicons -->
    <link rel="icon" href="/favicons/favicon.ico" sizes="any" />
    <link rel="icon" type="image/svg+xml" href="/favicons/favicon.svg" />
    <link
      rel="icon"
      type="image/png"
      sizes="96x96"
      href="/favicons/favicon-96x96.png"
    />

    <!-- Apple/iOS -->
    <link
      rel="apple-touch-icon"
      sizes="180x180"
      href="/favicons/apple-touch-icon.png"
    />
    <meta name="apple-mobile-web-app-capable" content="yes" />
    <meta name="mobile-web-app-capable" content="yes">
    <meta name="apple-mobile-web-app-status-bar-style" content="black" />

    <!-- Manifest for Android -->
    <link rel="manifest" href="/favicons/site.webmanifest" />

    <!-- Theme colors -->
    <meta name="theme-color" content="#000000" />
    <meta name="msapplication-TileColor" content="#000000" />

    <!-- Self-hosted fonts — preload only faces used above the fold:
         Oswald 700 (display/nav), Inter 400 (body), Cormorant 400 (home tagline / album titles) -->
    <link rel="preload" href="/fonts/oswald-700-latin.woff2" as="font" type="font/woff2" crossorigin="anonymous" />
    <link rel="preload" href="/fonts/inter-400-latin.woff2" as="font" type="font/woff2" crossorigin="anonymous" />
    <link rel="preload" href="/fonts/cormorant-garamond-400-latin.woff2" as="font" type="font/woff2" crossorigin="anonymous" />

    <!-- Global Styles -->
    <ViewTransitions />
  </head>
  <body class:list={[{ "home-page": isHome }, bgImage]}>
    <!-- Sigil Spine — vertical nav rail pinned to the right edge -->
    <nav class="spine" aria-label="Main navigation">
      <a
        href="/"
        class:list={["spine__link", { "spine__link--active": isHome }]}
        aria-current={isHome ? "page" : undefined}
      >
        <span class="spine__label">Home</span>
        <Icon name="home" title="Home" />
      </a>
      <a
        href="/about"
        class:list={["spine__link", { "spine__link--active": isAbout }]}
        aria-current={isAbout ? "page" : undefined}
      >
        <span class="spine__label">About</span>
        <Icon name="about" title="About" />
      </a>
      <a
        href="/listen"
        class:list={["spine__link", { "spine__link--active": isListen }]}
        aria-current={isListen ? "page" : undefined}
      >
        <span class="spine__label">Listen</span>
        <Icon name="listen" title="Listen" />
      </a>
      <a
        href="/archive"
        class:list={["spine__link", { "spine__link--active": isArchive }]}
        aria-current={isArchive ? "page" : undefined}
      >
        <span class="spine__label">Archive</span>
        <Icon name="archive" title="Archive" />
      </a>
    </nav>

    <!-- Main Content Area -->
    <main class="page-content">
      <slot />
    </main>

    <script>
      // Disable scroll during transition
      document.addEventListener("astro:before-preparation", () => {
        document.body.style.overflow = "hidden";
      });

      document.addEventListener("astro:after-swap", () => {
        window.scrollTo(0, 0);
        setTimeout(() => {
          document.body.style.overflow = "";
        }, 750);
      });

      // Ensure navigation stays fixed by moving it to body if needed
      function ensureNavFixed() {
        const nav = document.querySelector(".spine");
        if (nav && nav.parentElement !== document.body) {
          document.body.appendChild(nav);
        }
      }

      document.addEventListener("DOMContentLoaded", ensureNavFixed);
      document.addEventListener("astro:after-swap", ensureNavFixed);
    </script>
  </body>
</html>

<style is:global>
  @import "../styles/global.scss";
</style>

<style lang="scss">
  // Body background
  body {
    background-repeat: no-repeat;

    &.body__home {
      background-image: url("/images/occult-bgs/bg-1.png");
      background-position: center;
      background-size: cover;

      @media (max-width: 768px) {
        background-size: 400%;
      }
    }

    &.body__listen {
      background-image: url("/images/occult-bgs/bg-2.png");
      background-position: top;
      background-size: cover;

      background-blend-mode: multiply;
      background-color: rgba(25, 25, 25, 0.7);

      @media (max-width: 768px) {
        background-size: 400%;
        background-position: top;
        background-repeat: repeat;
      }
    }

    &.body__archive {
      background-image: url("/images/occult-bgs/bg-5.png");
      background-position: top;
      background-size: 175%;
      background-blend-mode: multiply;
      background-color: rgba(25, 25, 25);

      @media (max-width: 768px) {
        background-size: 300%;
        background-position: top;
      }
    }
  }

  // Screen reader only class
  .sr-only {
    position: absolute;
    width: 1px;
    height: 1px;
    padding: 0;
    margin: -1px;
    overflow: hidden;
    clip: rect(0, 0, 0, 0);
    white-space: nowrap;
    border-width: 0;
  }

  // Sigil Spine — vertical nav rail, right edge, glyphs threaded by a hairline
  .spine {
    position: fixed;
    top: 50%;
    right: 40px;
    transform: translateY(-50%);
    z-index: 10000;
    display: flex;
    flex-direction: column;
    align-items: center;
    gap: 30px;

    // the "spine" — a faint vertical line running behind the glyph column
    &::before {
      content: "";
      position: absolute;
      top: -6px;
      bottom: -6px;
      left: 50%;
      width: 1px;
      transform: translateX(-50%);
      background: linear-gradient(
        to bottom,
        transparent,
        var(--color-rust) 12%,
        var(--color-rust) 88%,
        transparent
      );
      opacity: 0.5;
      z-index: -1;
    }

    @media (max-width: 768px) {
      right: 22px;
      gap: 24px;
    }
  }

  .spine__link {
    position: relative;
    display: flex;
    align-items: center;
    justify-content: center;
    text-decoration: none;
    color: var(--color-gray-medium);
    transition: color 0.3s ease;
    --icon-size: 26px;

    @media (max-width: 768px) {
      --icon-size: 21px;
    }

    // Active page → bone glyph. (hover, declared after, intentionally wins.)
    &--active {
      color: var(--color-bone);
    }

    &:hover,
    &:focus-visible {
      color: var(--color-rust);
    }

    &:focus-visible {
      outline: 2px solid var(--color-bone);
      outline-offset: 6px;
      border-radius: 2px;
    }
  }

  // Label sits to the LEFT of the glyph; colour follows the link
  // (bone when active, rust when hovered/focused).
  .spine__label {
    position: absolute;
    right: calc(100% + 0.85rem);
    top: 50%;
    transform: translateY(-50%) translateX(6px);
    font-family: "Oswald", sans-serif;
    font-size: 0.7rem;
    font-weight: 600;
    text-transform: uppercase;
    letter-spacing: 0.2em;
    white-space: nowrap;
    color: inherit;
    opacity: 0;
    pointer-events: none;
    transition: opacity 0.3s ease, transform 0.3s ease;
  }

  // Active label stays visible; hover/focus reveals any link's label too.
  .spine__link--active .spine__label,
  .spine__link:hover .spine__label,
  .spine__link:focus-visible .spine__label {
    opacity: 1;
    transform: translateY(-50%) translateX(0);
  }

  @media (prefers-reduced-motion: reduce) {
    .spine__label {
      transition: opacity 0.01ms;
      transform: translateY(-50%);
    }
  }

  // Page Content Area
  .page-content {
    min-height: 100vh;
  }
</style>

<style is:global>
  /* View Transitions - Slide with Crossfade */
  @keyframes slideFromRight {
    from {
      transform: translateX(100%);
      opacity: 0;
    }
    to {
      transform: translateX(0);
      opacity: 1;
    }
  }

  @keyframes fadeOut {
    from {
      opacity: 1;
    }
    to {
      opacity: 0;
    }
  }

  ::view-transition-old(root) {
    animation: fadeOut 750ms cubic-bezier(0.65, 0, 0.35, 1);
  }

  ::view-transition-new(root) {
    animation: slideFromRight 750ms cubic-bezier(0.65, 0, 0.35, 1);
  }
</style>
