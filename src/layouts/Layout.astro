---
import { ViewTransitions } from "astro:transitions";

export interface Props {
  title: string;
  description?: string;
}

const { title, description = "Unofficial fan site" } = Astro.props;
const currentPath = Astro.url.pathname;

// Determine active page
const isHome = currentPath === "/";
const isListen = currentPath.startsWith("/listen");
const isArchive = currentPath.startsWith("/archive");

const bgImage = isListen
  ? "body__listen"
  : isArchive
    ? "body__archive"
    : "body__home";
---

<!doctype html>
<html lang="en">
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title>{title}</title>
    <meta name="description" content={description} />

    <!-- Standard favicons -->
    <link
      rel="icon"
      type="image/png"
      sizes="32x32"
      href="/favicons/favicon-32x32.png"
    />
    <link
      rel="icon"
      type="image/png"
      sizes="96x96"
      href="/favicons/favicon-96x96.png"
    />
    <link rel="icon" type="image/svg+xml" href="/favicons/favicon.svg" />

    <!-- Apple/iOS -->
    <link
      rel="apple-touch-icon"
      sizes="180x180"
      href="/favicons/apple-touch-icon.png"
    />
    <meta name="apple-mobile-web-app-capable" content="yes" />
    <meta name="mobile-web-app-capable" content="yes">
    <meta name="apple-mobile-web-app-status-bar-style" content="black" />

    <!-- Manifest for Android -->
    <link rel="manifest" href="/favicons/site.webmanifest" />

    <!-- Theme colors -->
    <meta name="theme-color" content="#000000" />
    <meta name="msapplication-TileColor" content="#000000" />

    <!-- Google Fonts -->
    <link rel="preconnect" href="https://fonts.googleapis.com" />
    <link
      href="https://fonts.googleapis.com/css2?family=Oswald:wght@400;700&family=Inter:wght@400;700&display=swap"
      rel="stylesheet"
    />

    <!-- Global Styles -->
    <ViewTransitions />
  </head>
  <body class:list={[{ "home-page": isHome }, bgImage]}>
    <!-- Navigation Dots -->
    <nav class="nav-dots" aria-label="Main navigation">
      <a
        href="/"
        class:list={["nav-dots__dot", { "nav-dots__dot--active": isHome }]}
        aria-label="Home"
        aria-current={isHome ? "page" : undefined}
      >
        <img
          src={isHome
            ? "/images/icon-home-active.svg"
            : "/images/icon-home-static.svg"}
          alt=""
          class="nav-dots__symbol nav-dots__symbol--home"
        />
        <img
          src="/images/icon-home-hover.svg"
          alt=""
          class="nav-dots__symbol-hover nav-dots__symbol-hover--home"
        />
        <span class="sr-only">Home</span>
      </a>
      <a
        href="/listen"
        class:list={["nav-dots__dot", { "nav-dots__dot--active": isListen }]}
        aria-label="Listen"
        aria-current={isListen ? "page" : undefined}
      >
        <img
          src={isListen
            ? "/images/icon-listen-active.svg"
            : "/images/icon-listen-static.svg"}
          alt=""
          class="nav-dots__symbol nav-dots__symbol--listen"
        />
        <img
          src="/images/icon-listen-hover.svg"
          alt=""
          class="nav-dots__symbol-hover nav-dots__symbol-hover--listen"
        />
        <span class="sr-only">Listen</span>
      </a>
      <a
        href="/archive"
        class:list={["nav-dots__dot", { "nav-dots__dot--active": isArchive }]}
        aria-label="Archive"
        aria-current={isArchive ? "page" : undefined}
      >
        <img
          src={isArchive
            ? "/images/icon-archive-active.svg"
            : "/images/icon-archive-static.svg"}
          alt=""
          class="nav-dots__symbol nav-dots__symbol--archive"
        />
        <img
          src="/images/icon-archive-hover.svg"
          alt=""
          class="nav-dots__symbol-hover nav-dots__symbol-hover--archive"
        />
        <span class="sr-only">Archive</span>
      </a>
    </nav>

    <!-- Main Content Area -->
    <main class="page-content">
      <slot />
    </main>

    <script>
      // Disable scroll during transition
      document.addEventListener("astro:before-preparation", () => {
        document.body.style.overflow = "hidden";
      });

      document.addEventListener("astro:after-swap", () => {
        window.scrollTo(0, 0);
        setTimeout(() => {
          document.body.style.overflow = "";
        }, 750);
      });

      // Ensure navigation stays fixed by moving it to body if needed
      function ensureNavFixed() {
        const nav = document.querySelector(".nav-dots");
        if (nav && nav.parentElement !== document.body) {
          document.body.appendChild(nav);
        }
      }

      document.addEventListener("DOMContentLoaded", ensureNavFixed);
      document.addEventListener("astro:after-swap", ensureNavFixed);
    </script>
  </body>
</html>

<style is:global>
  @import "../styles/global.scss";
</style>

<style lang="scss">
  // Body background
  body {
    background-repeat: no-repeat;

    &.body__home {
      background-image: url("/images/bg-1.png");
      background-position: center;
      background-size: cover;

      @media (max-width: 768px) {
        background-size: 400%;
      }
    }

    &.body__listen {
      background-image: url("/images/bg-2.png");
      background-position: top;
      background-size: cover;

      background-blend-mode: multiply;
      background-color: rgba(25, 25, 25, 0.7);

      @media (max-width: 768px) {
        background-size: 400%;
        background-position: top;
        background-repeat: repeat;
      }
    }

    &.body__archive {
      background-image: url("/images/bg-5.png");
      background-position: top;
      background-size: 175%;
      background-blend-mode: multiply;
      background-color: rgba(25, 25, 25);

      @media (max-width: 768px) {
        background-size: 300%;
        background-position: top;
      }
    }
  }

  // Screen reader only class
  .sr-only {
    position: absolute;
    width: 1px;
    height: 1px;
    padding: 0;
    margin: -1px;
    overflow: hidden;
    clip: rect(0, 0, 0, 0);
    white-space: nowrap;
    border-width: 0;
  }

  // Navigation Dots
  .nav-dots {
    position: fixed;
    top: 30px;
    right: 50px;
    z-index: 10000;
    display: flex;
    flex-direction: row;
    gap: 50px;

    @media (max-width: 768px) {
      top: 30px;
      right: 30px;
      gap: 30px;
    }
  }

  .nav-dots__dot {
    cursor: pointer;
    display: flex;
    align-items: flex-start;
    justify-content: center;
    text-decoration: none;
    position: relative;
  }

  .nav-dots__symbol {
    display: block;
    transition: opacity 0.3s ease;
    position: relative;
    z-index: 2;

    // Individual icon size adjustments
    &--home {
      width: 30px;
      height: 30px;

      @media (max-width: 768px) {
        width: 23px;
        height: 23px;
      }
    }

    &--listen {
      width: 30px;
      height: 28px;

      @media (max-width: 768px) {
        width: 20px;
        height: 20px;
      }
    }

    &--archive {
      width: 29px;
      height: 29px;

      @media (max-width: 768px) {
        width: 21px;
        height: 21px;
      }
    }
  }

  .nav-dots__symbol-hover {
    display: block;
    position: absolute;
    top: 0;
    left: 0;
    opacity: 0;
    transition: opacity 0.3s ease;
    z-index: 1;
    pointer-events: none;

    // Individual icon size adjustments (must match symbol sizes)
    &--home {
      width: 30px;
      height: 30px;

      @media (max-width: 768px) {
        width: 23px;
        height: 23px;
      }
    }

    &--listen {
      width: 30px;
      height: 28px;

      @media (max-width: 768px) {
        width: 20px;
        height: 20px;
      }
    }

    &--archive {
      width: 28px;
      height: 28px;

      @media (max-width: 768px) {
        width: 20px;
        height: 20px;
      }
    }
  }

  .nav-dots__dot:hover .nav-dots__symbol {
    opacity: 0;
  }

  .nav-dots__dot:hover .nav-dots__symbol-hover {
    opacity: 1;
  }

  // Disable hover effect on active pages
  .nav-dots__dot--active:hover .nav-dots__symbol {
    opacity: 1;
  }

  .nav-dots__dot--active:hover .nav-dots__symbol-hover {
    opacity: 0;
  }

  // Page Content Area
  .page-content {
    min-height: 100vh;
  }
</style>

<style is:global>
  /* View Transitions - Slide with Crossfade */
  @keyframes slideFromRight {
    from {
      transform: translateX(100%);
      opacity: 0;
    }
    to {
      transform: translateX(0);
      opacity: 1;
    }
  }

  @keyframes fadeOut {
    from {
      opacity: 1;
    }
    to {
      opacity: 0;
    }
  }

  ::view-transition-old(root) {
    animation: fadeOut 750ms cubic-bezier(0.65, 0, 0.35, 1);
  }

  ::view-transition-new(root) {
    animation: slideFromRight 750ms cubic-bezier(0.65, 0, 0.35, 1);
  }
</style>
