---
import { ViewTransitions } from 'astro:transitions';

export interface Props {
  title: string;
  description?: string;
}

const { title, description = "Unofficial fan site" } = Astro.props;
const currentPath = Astro.url.pathname;

// Determine active page
const isHome = currentPath === '/';
const isListen = currentPath.startsWith('/listen');
const isArchive = currentPath.startsWith('/archive');

const bgImage = isListen ? "body__listen" : isArchive ? "body__archive" : "body__home";
---

<!DOCTYPE html>
<html lang="en">
<head>
  <meta charset="UTF-8">
  <meta name="viewport" content="width=device-width, initial-scale=1.0">
  <title>{title}</title>
  <meta name="description" content={description}>

  <!-- Favicon -->
  <link rel="icon" type="image/svg+xml" href="/favicon/favicon.svg">
  <link rel="icon" type="image/png" sizes="96x96" href="/favicon/favicon-96x96.png">
  <link rel="apple-touch-icon" sizes="180x180" href="/favicon/apple-touch-icon.png">
  <link rel="manifest" href="/favicon/site.webmanifest">

  <!-- Mobile status bar -->
  <meta name="theme-color" content="#000000">
  <meta name="apple-mobile-web-app-status-bar-style" content="black-translucent">

  <!-- Google Fonts -->
  <link rel="preconnect" href="https://fonts.googleapis.com">
  <link href="https://fonts.googleapis.com/css2?family=Oswald:wght@400;700&family=Inter:wght@400;700&display=swap" rel="stylesheet">

  <!-- Global Styles -->
  <ViewTransitions />
</head>
<body class:list={[{ "home-page": isHome }, bgImage]}>
  <!-- Navigation Dots -->
  <nav class="nav-dots" aria-label="Main navigation">
    <a
      href="/"
      class:list={["nav-dots__dot", { "nav-dots__dot--active": isHome }]}
      aria-label="Home"
      aria-current={isHome ? "page" : undefined}
    >
      <span class="nav-dots__symbol nav-dots__symbol--home">🝆</span>
      <span class="sr-only">Home</span>
    </a>
    <a
      href="/listen"
      class:list={["nav-dots__dot", { "nav-dots__dot--active": isListen }]}
      aria-label="Listen"
      aria-current={isListen ? "page" : undefined}
    >
      <span class="nav-dots__symbol nav-dots__symbol--listen">⚷</span>
      <span class="sr-only">Listen</span>
    </a>
    <a
      href="/archive"
      class:list={["nav-dots__dot", { "nav-dots__dot--active": isArchive }]}
      aria-label="Archive"
      aria-current={isArchive ? "page" : undefined}
    >
      <span class="nav-dots__symbol nav-dots__symbol--archive">☋</span>
      <span class="sr-only">Archive</span>
    </a>
  </nav>

  <!-- Main Content Area -->
  <main class="page-content">
    <slot />
  </main>

<script>
    // Disable scroll during transition
    document.addEventListener('astro:before-preparation', () => {
      document.body.style.overflow = 'hidden';
    });

    document.addEventListener('astro:after-swap', () => {
      window.scrollTo(0, 0);
      setTimeout(() => {
        document.body.style.overflow = '';
      }, 750);
    });

    // Ensure navigation stays fixed by moving it to body if needed
    function ensureNavFixed() {
      const nav = document.querySelector('.nav-dots');
      if (nav && nav.parentElement !== document.body) {
        document.body.appendChild(nav);
      }
    }

    document.addEventListener('DOMContentLoaded', ensureNavFixed);
    document.addEventListener('astro:after-swap', ensureNavFixed);
  </script>
</body>
</html>

<style is:global>
  @import '../styles/global.scss';
</style>

<style lang="scss">
  // Body background
  body {
    // background-image: url('/images/key-bg-3.png');
    // background-size: cover;
    background-repeat: no-repeat;
    // background-attachment: fixed;
    // background-color: rgba(0, 0, 0, .9);
    // background-blend-mode: soft-light;

    &.body__home {
      background-image: url('/images/bg-1.png');
      background-position: center;
      background-size: cover;

      // background-color: rgba(25, 25, 25);
      // background-blend-mode: multiply;
      // filter: brightness(1.5) contrast(.9);

      @media (max-width: 768px) {
        background-size: 400%;
      }
    }

    &.body__listen {
      background-image: url('/images/bg-2.png');
      background-position: top;
      background-size: cover;

      // background-color: rgba(25, 25, 25);
      // background-blend-mode: multiply;
      @media (max-width: 768px) {
        background-size: 400%;
        // background-size: 700%;
        background-position: top;
        // background-position: 50% bottom;
        background-repeat: repeat;

      }
    }

    &.body__archive {
      background-image: url('/images/bg-5.png');
      background-position: top;
      background-size: 175%;
      // background-size: cover;
      background-blend-mode: multiply;
      background-color: rgba(25, 25, 25);

      @media (max-width: 768px) {
        background-size: 300%;
        background-position: top;

      }
    }
  }

  // Screen reader only class
  .sr-only {
    position: absolute;
    width: 1px;
    height: 1px;
    padding: 0;
    margin: -1px;
    overflow: hidden;
    clip: rect(0, 0, 0, 0);
    white-space: nowrap;
    border-width: 0;
  }

  // Navigation Dots
  .nav-dots {
    position: fixed;
    top: 30px;
    right: 50px;
    z-index: 10000;
    display: flex;
    flex-direction: row;
    gap: 50px;

    @media (max-width: 768px) {
      top: 30px;
      right: 30px;
      gap: 30px;
    }
  }

  .nav-dots__dot {
    cursor: pointer;
    display: flex;
    align-items: flex-start;
    justify-content: center;
    text-decoration: none;
  }

  .nav-dots__symbol {
    font-size: 2.5rem;
    font-weight: 900;
    color: #8b7355; // Inactive: blood
    // color: rgba(139, 0, 0, 0.5); // Inactive: blood
    transition: color 0.3s ease;
    display: block;

    @media (max-width: 768px) {
      font-size: 1.75rem;
    }

    &--home {
      font-size: 3.25rem;
      position: relative;
      top: -25px; // Adjust to align with others
      @media (max-width: 768px) {
        top: -22px;
      font-size: 2.5rem;
    }
    }

    &--listen {
      position: relative;
      font-size: 2.25rem;
      top: 0; // Baseline reference
      @media (max-width: 768px) {
      font-size: 1.6rem;
    }
    }

    &--archive {
      position: relative;
      font-size: 2.5rem;
      top: -1px; // Adjust to align with others
      @media (max-width: 768px) {
      font-size: 1.75rem;
    }
    }
  }

  .nav-dots__dot:hover .nav-dots__symbol {
    // color: #8B0000; // Hover: rust
    color: #5a3a2a; // Hover: rust
  }

  .nav-dots__dot--active .nav-dots__symbol {
    color: #cccccc; // Active: bone
    // color: #8b7355; // Active: bone
  }

  // Page Content Area
  .page-content {
    min-height: 100vh;
  }
</style>

<style is:global>
  /* View Transitions - Slide with Crossfade */
  @keyframes slideFromRight {
    from {
      transform: translateX(100%);
      opacity: 0;
    }
    to {
      transform: translateX(0);
      opacity: 1;
    }
  }

  @keyframes fadeOut {
    from {
      opacity: 1;
    }
    to {
      opacity: 0;
    }
  }

  ::view-transition-old(root) {
    animation: fadeOut 750ms cubic-bezier(0.65, 0, 0.35, 1);
  }

  ::view-transition-new(root) {
    animation: slideFromRight 750ms cubic-bezier(0.65, 0, 0.35, 1);
  }
</style>
