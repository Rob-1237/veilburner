---
import { ViewTransitions } from 'astro:transitions';

export interface Props {
  title: string;
  description?: string;
}

const { title, description = "Unofficial fan site" } = Astro.props;
const currentPath = Astro.url.pathname;

// Determine active page
const isHome = currentPath === '/';
const isListen = currentPath.startsWith('/listen');
const isArchive = currentPath.startsWith('/archive');
---

<!DOCTYPE html>
<html lang="en">
<head>
  <meta charset="UTF-8">
  <meta name="viewport" content="width=device-width, initial-scale=1.0">
  <title>{title}</title>
  <meta name="description" content={description}>

  <!-- Mobile status bar -->
  <meta name="theme-color" content="#000000">
  <meta name="apple-mobile-web-app-status-bar-style" content="black-translucent">

  <!-- Google Fonts -->
  <link rel="preconnect" href="https://fonts.googleapis.com">
  <link href="https://fonts.googleapis.com/css2?family=Oswald:wght@400;700&family=Inter:wght@400;700&display=swap" rel="stylesheet">

  <!-- Global Styles -->
  <ViewTransitions />
</head>
<body>
  <!-- Navigation Dots -->
  <nav class="nav-dots" aria-label="Main navigation">
    <a
      href="/"
      class:list={["nav-dots__dot", { "nav-dots__dot--active": isHome }]}
      aria-label="Home"
      aria-current={isHome ? "page" : undefined}
    >
      <span class="sr-only">Home</span>
    </a>
    <a
      href="/listen"
      class:list={["nav-dots__dot", { "nav-dots__dot--active": isListen }]}
      aria-label="Listen"
      aria-current={isListen ? "page" : undefined}
    >
      <span class="sr-only">Listen</span>
    </a>
    <a
      href="/archive"
      class:list={["nav-dots__dot", { "nav-dots__dot--active": isArchive }]}
      aria-label="Archive"
      aria-current={isArchive ? "page" : undefined}
    >
      <span class="sr-only">Archive</span>
    </a>
  </nav>

  <!-- Main Content Area -->
  <main class="page-content">
    <slot />
  </main>

  <!-- Fixed Footer -->
  <footer class="site-footer">
    <!-- SVG Filters for Glitch Effects -->
    <svg style="position: absolute; width: 0; height: 0;">
      <defs>
        <!-- CRT Displacement Filter -->
        <filter id="crt-displace">
          <feTurbulence type="fractalNoise" baseFrequency="0.05" numOctaves="2" result="turbulence" seed="2"/>
          <feDisplacementMap in="SourceGraphic" in2="turbulence" scale="0" xChannelSelector="R" yChannelSelector="G">
            <animate attributeName="scale" values="0;8;0" dur="0.2s" begin="indefinite" fill="freeze" id="crt-anim"/>
          </feDisplacementMap>
        </filter>

        <!-- Static Noise Filter -->
        <filter id="static-noise">
          <feTurbulence type="fractalNoise" baseFrequency="0.9" numOctaves="4" result="noise"/>
          <feColorMatrix in="noise" type="saturate" values="0"/>
          <feBlend in="SourceGraphic" in2="noise" mode="multiply" result="blend"/>
          <feComposite in="blend" in2="SourceGraphic" operator="atop"/>
        </filter>

        <!-- Scanlines -->
        <pattern id="scanlines" x="0" y="0" width="100%" height="8" patternUnits="userSpaceOnUse">
          <rect x="0" y="0" width="100%" height="2" fill="black" opacity="0.6"/>
        </pattern>
      </defs>
    </svg>

    <!-- Social Icons -->
    <div class="social-icons">
      <a href="https://veilburner.bandcamp.com/" target="_blank" rel="noopener noreferrer" class="social-icons__link" aria-label="Bandcamp">
        <svg xmlns="http://www.w3.org/2000/svg" viewBox="0 0 24 24" fill="currentColor">
          <path d="M0 18.75l7.437-13.5h16.563l-7.438 13.5z"/>
        </svg>
      </a>
      <a href="https://www.facebook.com/veilburner" target="_blank" rel="noopener noreferrer" class="social-icons__link" aria-label="Facebook">
        <svg xmlns="http://www.w3.org/2000/svg" viewBox="0 0 24 24" fill="currentColor">
          <path d="M24 12.073c0-6.627-5.373-12-12-12s-12 5.373-12 12c0 5.99 4.388 10.954 10.125 11.854v-8.385H7.078v-3.47h3.047V9.43c0-3.007 1.792-4.669 4.533-4.669 1.312 0 2.686.235 2.686.235v2.953H15.83c-1.491 0-1.956.925-1.956 1.874v2.25h3.328l-.532 3.47h-2.796v8.385C19.612 23.027 24 18.062 24 12.073z"/>
        </svg>
      </a>
      <a href="https://www.instagram.com/veilburner" target="_blank" rel="noopener noreferrer" class="social-icons__link" aria-label="Instagram">
        <svg xmlns="http://www.w3.org/2000/svg" viewBox="0 0 24 24" fill="currentColor">
          <path d="M12 2.163c3.204 0 3.584.012 4.85.07 3.252.148 4.771 1.691 4.919 4.919.058 1.265.069 1.645.069 4.849 0 3.205-.012 3.584-.069 4.849-.149 3.225-1.664 4.771-4.919 4.919-1.266.058-1.644.07-4.85.07-3.204 0-3.584-.012-4.849-.07-3.26-.149-4.771-1.699-4.919-4.92-.058-1.265-.07-1.644-.07-4.849 0-3.204.013-3.583.07-4.849.149-3.227 1.664-4.771 4.919-4.919 1.266-.057 1.645-.069 4.849-.069zm0-2.163c-3.259 0-3.667.014-4.947.072-4.358.2-6.78 2.618-6.98 6.98-.059 1.281-.073 1.689-.073 4.948 0 3.259.014 3.668.072 4.948.2 4.358 2.618 6.78 6.98 6.98 1.281.058 1.689.072 4.948.072 3.259 0 3.668-.014 4.948-.072 4.354-.2 6.782-2.618 6.979-6.98.059-1.28.073-1.689.073-4.948 0-3.259-.014-3.667-.072-4.947-.196-4.354-2.617-6.78-6.979-6.98-1.281-.059-1.69-.073-4.949-.073zm0 5.838c-3.403 0-6.162 2.759-6.162 6.162s2.759 6.163 6.162 6.163 6.162-2.759 6.162-6.163c0-3.403-2.759-6.162-6.162-6.162zm0 10.162c-2.209 0-4-1.79-4-4 0-2.209 1.791-4 4-4s4 1.791 4 4c0 2.21-1.791 4-4 4zm6.406-11.845c-.796 0-1.441.645-1.441 1.44s.645 1.44 1.441 1.44c.795 0 1.439-.645 1.439-1.44s-.644-1.44-1.439-1.44z"/>
        </svg>
      </a>
      <a href="mailto:burningtheveil@gmail.com" class="social-icons__link" aria-label="Email">
        <svg xmlns="http://www.w3.org/2000/svg" viewBox="0 0 24 24" fill="currentColor">
          <path d="M20 4H4c-1.1 0-1.99.9-1.99 2L2 18c0 1.1.9 2 2 2h16c1.1 0 2-.9 2-2V6c0-1.1-.9-2-2-2zm0 4l-8 5-8-5V6l8 5 8-5v2z"/>
        </svg>
      </a>
    </div>

    <p>Unofficial fan site. Not affiliated with Veilburner or Transcending Obscurity Records.</p>
    <p>&copy; 2025 Mettal Mussic</p>
  </footer>

<script>
    // Disable scroll during transition
    document.addEventListener('astro:before-preparation', () => {
      document.body.style.overflow = 'hidden';
    });

    document.addEventListener('astro:after-swap', () => {
      window.scrollTo(0, 0);
      setTimeout(() => {
        document.body.style.overflow = '';
      }, 750);
    });
  </script>
</body>
</html>

<style is:global>
  @import '../styles/global.scss';
</style>

<style lang="scss">
  // Screen reader only class
  .sr-only {
    position: absolute;
    width: 1px;
    height: 1px;
    padding: 0;
    margin: -1px;
    overflow: hidden;
    clip: rect(0, 0, 0, 0);
    white-space: nowrap;
    border-width: 0;
  }

  // Navigation Dots
  .nav-dots {
    position: fixed;
    top: 100px;
    right: 30px;
    z-index: 9999;
    display: flex;
    flex-direction: column;
    gap: 35px;

    @media (max-width: 768px) {
      top: auto;
      bottom: 30px;
      right: 50%;
      transform: translateX(50%);
      flex-direction: row;
    }
  }

  .nav-dots__dot {
    width: 14px;
    height: 14px;
    border-radius: 50%;
    background: rgba(139, 0, 0, 0.35); // Inactive: blood
    border: none;
    cursor: pointer;
    transition: background-color 0.3s ease;
    display: block;

    &:hover {
      background: #5a3a2a; // Hover: rust
    }

    &--active {
      background: #8b7355; // Active: bone
    }
  }

  // Page Content Area
  .page-content {
    min-height: calc(100vh - 120px); // Account for footer space
    padding-bottom: 120px; // Ensure content doesn't hide under footer
  }

  // Social Icons
  .social-icons {
    display: flex;
    justify-content: center;
    align-items: center;
    gap: 2rem;
    margin-bottom: 1rem;

    &__link {
      display: flex;
      align-items: center;
      justify-content: center;
      width: 32px;
      height: 32px;
      color: #5a3a2a; // Rust
      transition: color 0.3s ease;

      svg {
        width: 100%;
        height: 100%;
        filter: grayscale(100%) contrast(80%) brightness(90%);
        transition: filter 0.3s ease;
      }

      &:hover {
        color: #8b7355; // Bone

        svg {
          filter: grayscale(100%) contrast(100%) brightness(110%);
        }
      }
    }

    @media (max-width: 768px) {
      gap: 1.5rem;

      &__link {
        width: 28px;
        height: 28px;
      }
    }
  }

  // Fixed Footer
  .site-footer {
    display: flex;
    flex-direction: column;
    align-items: center;
    justify-content: center;
    position: fixed;
    bottom: 0;
    left: 0;
    right: 0;
    z-index: 9998; // Below nav dots, above content
    padding: 2rem 0;
    text-align: center;
    color: #666666;
    border-top: 1px solid #1a1a1a;
    background: #000000;

    p {
      font-size: 0.8rem;
      color: #666666;
      margin-top: 0.5rem;
    }
  }
</style>

<style is:global>
  /* View Transitions - Slide with Crossfade */
  @keyframes slideFromRight {
    from {
      transform: translateX(100%);
      opacity: 0;
    }
    to {
      transform: translateX(0);
      opacity: 1;
    }
  }

  @keyframes fadeOut {
    from {
      opacity: 1;
    }
    to {
      opacity: 0;
    }
  }

  ::view-transition-old(root) {
    animation: fadeOut 750ms cubic-bezier(0.65, 0, 0.35, 1);
  }

  ::view-transition-new(root) {
    animation: slideFromRight 750ms cubic-bezier(0.65, 0, 0.35, 1);
  }
</style>
