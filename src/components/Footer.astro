---
// Colophon footer — identity · navigate · elsewhere.
import Icon from './Icon.astro';

const nav = [
  { href: '/', label: 'Home' },
  { href: '/about', label: 'About' },
  { href: '/listen', label: 'Listen' },
  { href: '/archive', label: 'Archive' },
];

// Each link rests on its brand icon and reveals the matching sigil on hover/focus.
// (tometal uses its logo image; the others use brand-icon SVGs.)
const socials = [
  { href: 'https://veilburnerband.bandcamp.com/', label: 'Bandcamp', brand: 'bandcamp', sigil: 'shakuzu' },
  { href: 'https://www.facebook.com/veilburner', label: 'Facebook', brand: 'facebook', sigil: 'belial' },
  { href: 'https://www.instagram.com/veilburner_official/', label: 'Instagram', brand: 'instagram', sigil: 'saturn' },
  { href: 'https://tometal.com/?s=veilburner', label: 'Transcending Obscurity Records', brand: 'tometal', sigil: 'lilith' },
];
---

<footer class="colophon">
  <div class="colophon__inner">
    <div class="colophon__col colophon__identity">
      <p class="colophon__disclaimer">
        Unofficial fan site.<br />Not affiliated with Veilburner<br />or Transcending Obscurity Records.
      </p>
      <p class="colophon__copyright">&copy; 2026 Garfish Digital</p>
    </div>

    <nav class="colophon__col colophon__nav" aria-label="Footer">
      <h2 class="colophon__heading">Navigate</h2>
      <ul class="colophon__links">
        {nav.map((item) => (
          <li><a href={item.href}>{item.label}</a></li>
        ))}
      </ul>
    </nav>

    <div class="colophon__col colophon__social">
      <h2 class="colophon__heading">Elsewhere</h2>
      <div class="colophon__sigils">
        {socials.map((s) => (
          <a
            href={s.href}
            target="_blank"
            rel="noopener noreferrer"
            class="colophon__social"
            aria-label={s.label}
          >
            {s.brand === 'tometal' ? (
              <img src="/images/tometal-logo-web-tint.jpg" alt="" class="colophon__brand colophon__brand--logo" />
            ) : (
              <Icon name={s.brand} class="colophon__brand" />
            )}
            <Icon name={s.sigil} class="colophon__reveal" />
          </a>
        ))}
      </div>
    </div>
  </div>
</footer>

<style lang="scss">
  @import '../styles/tokens';

  .colophon {
    border-top: 1px solid var(--color-gray-dark);
    background: var(--color-void);
    padding: $spacing-2xl clamp(1.5rem, 5vw, 5rem) $spacing-xl;
  }

  .colophon__inner {
    max-width: 1600px;
    margin: 0 auto;
    display: grid;
    grid-template-columns: 2fr 1fr 1fr;
    gap: $spacing-xl;
    align-items: start;

    @media (max-width: 768px) {
      grid-template-columns: 1fr;
      gap: $spacing-xl;
    }
  }

  .colophon__heading {
    font-family: $font-metal;
    font-size: 0.8rem;
    font-weight: 600;
    text-transform: uppercase;
    letter-spacing: 0.2em;
    color: var(--color-bone);
    margin-bottom: $spacing-md;
  }

  .colophon__disclaimer {
    font-size: 0.8rem;
    line-height: 1.7;
    color: var(--color-gray-medium);
    margin-bottom: $spacing-md;
  }

  .colophon__copyright {
    font-family: $font-metal;
    font-size: 0.8rem;
    letter-spacing: 0.1em;
    color: var(--color-rust);
  }

  .colophon__links {
    list-style: none;
    display: flex;
    flex-direction: column;
    gap: $spacing-xs;

    a {
      font-family: $font-body;
      font-size: 0.9rem;
      color: var(--color-gray-medium);
      text-decoration: none;
      letter-spacing: 0.05em;
      transition: color 0.3s ease;

      &:hover,
      &:focus-visible {
        color: var(--color-bone);
      }
    }
  }

  .colophon__sigils {
    display: flex;
    flex-wrap: wrap;
    align-items: center;
    gap: $spacing-lg;
  }

  // Each link rests on its brand icon and reveals the matching sigil on hover/focus.
  .colophon__social {
    position: relative;
    display: inline-flex;
    align-items: center;
    height: 40px;
    color: var(--color-bone);
    transition: color 0.3s ease, transform 0.3s ease;

    &:hover,
    &:focus-visible {
      color: var(--color-rust);
      transform: translateY(-2px);
    }

    &:focus-visible {
      outline: 2px solid var(--color-bone);
      outline-offset: 6px;
      border-radius: 2px;
    }

    @media (prefers-reduced-motion: reduce) {
      transition: color 0.3s ease;

      &:hover,
      &:focus-visible {
        transform: none;
      }
    }
  }

  // Resting brand icon (in-flow — defines each link's width)
  .colophon__brand {
    --icon-size: 34px;
    transition: opacity 0.3s ease;

    &--logo {
      height: 40px;
      width: auto;
      display: block;
    }
  }

  // Matching sigil, revealed on hover/focus (overlay, centred, hidden at rest)
  .colophon__reveal {
    --icon-size: 40px;
    position: absolute;
    top: 50%;
    left: 50%;
    transform: translate(-50%, -50%);
    color: var(--color-rust);
    opacity: 0;
    pointer-events: none;
    transition: opacity 0.3s ease;
  }

  .colophon__social:hover .colophon__brand,
  .colophon__social:focus-visible .colophon__brand {
    opacity: 0;
  }

  .colophon__social:hover .colophon__reveal,
  .colophon__social:focus-visible .colophon__reveal {
    opacity: 1;
  }
</style>
