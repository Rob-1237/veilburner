---
// Colophon footer — identity · navigate · elsewhere.
import Icon from './Icon.astro';

const nav = [
  { href: '/', label: 'Home' },
  { href: '/about', label: 'About' },
  { href: '/listen', label: 'Listen' },
  { href: '/archive', label: 'Archive' },
];

// Sigil ↔ destination mapping (preserved from the original footer)
const socials = [
  { href: 'https://veilburnerband.bandcamp.com/', label: 'Bandcamp', sigil: 'shakuzu' },
  { href: 'https://www.facebook.com/veilburner', label: 'Facebook', sigil: 'belial' },
  { href: 'https://www.instagram.com/veilburner_official/', label: 'Instagram', sigil: 'saturn' },
  { href: 'https://tometal.com/?s=veilburner', label: 'Transcending Obscurity Records', sigil: 'lilith' },
];
---

<footer class="colophon">
  <div class="colophon__inner">
    <div class="colophon__col colophon__identity">
      <p class="colophon__disclaimer">
        Unofficial fan site.<br />Not affiliated with Veilburner<br />or Transcending Obscurity Records.
      </p>
      <p class="colophon__copyright">&copy; 2026 Garfish Digital</p>
    </div>

    <nav class="colophon__col colophon__nav" aria-label="Footer">
      <h2 class="colophon__heading">Navigate</h2>
      <ul class="colophon__links">
        {nav.map((item) => (
          <li><a href={item.href}>{item.label}</a></li>
        ))}
      </ul>
    </nav>

    <div class="colophon__col colophon__social">
      <h2 class="colophon__heading">Elsewhere</h2>
      <div class="colophon__sigils">
        {socials.map((s) => (
          <a
            href={s.href}
            target="_blank"
            rel="noopener noreferrer"
            class="colophon__sigil"
            aria-label={s.label}
          >
            <Icon name={s.sigil} />
          </a>
        ))}
      </div>
    </div>
  </div>
</footer>

<style lang="scss">
  @import '../styles/tokens';

  .colophon {
    border-top: 1px solid var(--color-gray-dark);
    background: var(--color-void);
    padding: $spacing-2xl $spacing-lg $spacing-xl;
  }

  .colophon__inner {
    max-width: 1200px;
    margin: 0 auto;
    display: grid;
    grid-template-columns: 1.5fr 1fr 1fr;
    gap: $spacing-2xl;
    align-items: start;

    @media (max-width: 768px) {
      grid-template-columns: 1fr;
      gap: $spacing-xl;
    }
  }

  .colophon__heading {
    font-family: $font-metal;
    font-size: 0.8rem;
    font-weight: 600;
    text-transform: uppercase;
    letter-spacing: 0.2em;
    color: var(--color-bone);
    margin-bottom: $spacing-md;
  }

  .colophon__disclaimer {
    font-size: 0.8rem;
    line-height: 1.7;
    color: var(--color-gray-medium);
    margin-bottom: $spacing-md;
  }

  .colophon__copyright {
    font-family: $font-metal;
    font-size: 0.8rem;
    letter-spacing: 0.1em;
    color: var(--color-rust);
  }

  .colophon__links {
    list-style: none;
    display: flex;
    flex-direction: column;
    gap: $spacing-xs;

    a {
      font-family: $font-body;
      font-size: 0.9rem;
      color: var(--color-gray-medium);
      text-decoration: none;
      letter-spacing: 0.05em;
      transition: color 0.3s ease;

      &:hover,
      &:focus-visible {
        color: var(--color-bone);
      }
    }
  }

  .colophon__sigils {
    display: flex;
    flex-wrap: wrap;
    gap: $spacing-md;
  }

  .colophon__sigil {
    --icon-size: 44px;
    display: inline-flex;
    color: var(--color-rust);
    transition: color 0.3s ease, filter 0.3s ease, transform 0.3s ease;

    &:hover,
    &:focus-visible {
      color: var(--color-bone);
      filter: drop-shadow(0 0 6px rgba(139, 0, 0, 0.55));
      transform: translateY(-2px);
    }

    &:focus-visible {
      outline: 2px solid var(--color-bone);
      outline-offset: 4px;
      border-radius: 2px;
    }

    @media (prefers-reduced-motion: reduce) {
      transition: color 0.3s ease;

      &:hover,
      &:focus-visible {
        transform: none;
      }
    }
  }
</style>
