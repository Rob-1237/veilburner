---
// Colophon footer — identity · navigate · elsewhere.
import Icon from './Icon.astro';

const nav = [
  { href: '/', label: 'Home' },
  { href: '/about', label: 'About' },
  { href: '/listen', label: 'Listen' },
  { href: '/archive', label: 'Archive' },
];

// Each link rests on its brand icon and reveals the matching sigil on hover/focus.
// (tometal uses its logo image; the others use brand-icon SVGs.)
const socials = [
  { href: 'https://veilburnerband.bandcamp.com/', label: 'Bandcamp', brand: 'bandcamp', sigil: 'shakuzu' },
  { href: 'https://www.facebook.com/veilburner', label: 'Facebook', brand: 'facebook', sigil: 'belial' },
  { href: 'https://www.instagram.com/veilburner_official/', label: 'Instagram', brand: 'instagram', sigil: 'saturn' },
  { href: 'https://tometal.com/?s=veilburner', label: 'Transcending Obscurity Records', brand: 'vinyl', sigil: 'lilith' },
];
---

<footer class="colophon">
  <div class="colophon__inner">
   
    <div class="colophon__col colophon__social">
      <!-- <h2 class="colophon__heading">Elsewhere</h2> -->
      <div class="colophon__sigils">
        {socials.map((s) => (
          <a
            href={s.href}
            target="_blank"
            rel="noopener noreferrer"
            class="colophon__social"
            aria-label={s.label}
          >
            <Icon name={s.brand} class="colophon__brand" />
            {/* Sigil-reveal concept on hold — uncomment to restore the hover reveal
            <Icon name={s.sigil} class="colophon__reveal" />
            */}
          </a>
        ))}
      </div>
    </div>

    <nav class="colophon__col colophon__nav" aria-label="Footer">
      <!-- <h2 class="colophon__heading">Navigate</h2> -->
      <ul class="colophon__links">
        {nav.map((item) => (
          <li><a href={item.href}>{item.label}</a></li>
        ))}
      </ul>
    </nav>

     <div class="colophon__col colophon__identity">
      <!-- <h2 class="colophon__heading">Developer</h2> -->
      <p class="colophon__copyright">
        <span class="colophon__disclaimer">An unofficial fan site.</span><br />
        &copy; 2026 <a href="https://garfishdigital.com" target="_blank" rel="noopener noreferrer" class="colophon__dev-link">Garfish Digital</a>
        </p>
    </div>

  </div>
</footer>

<style lang="scss">
  @import '../styles/tokens';

  .colophon {
    border-top: 1px solid var(--color-gray-dark);
    background: var(--color-void);
    padding: $spacing-2xl clamp(1.5rem, 5vw, 5rem) $spacing-xl;
  }

  .colophon__inner {
    margin: 0 auto;
    display: grid;
    grid-template-columns: repeat(3, 1fr);
    gap: $spacing-xl;
    align-items: start;

    @media (max-width: 768px) {
      grid-template-columns: 1fr;
      gap: $spacing-2xl;
    }
  }

  // Each column: heading on top, content centred beneath — consistent across all three
  .colophon__col {
    display: flex;
    flex-direction: column;
    align-items: center;
    text-align: center;
    gap: $spacing-md;
  }

  .colophon__heading {
    font-family: $font-metal;
    font-size: 0.8rem;
    font-weight: 600;
    text-transform: uppercase;
    letter-spacing: 0.2em;
    color: var(--color-bone);
  }

  .colophon__disclaimer {
    font-size: 0.8rem;
    line-height: 1.7;
    color: var(--color-gray-medium);
  }

  .colophon__copyright {
    font-family: $font-metal;
    font-size: 0.8rem;
    letter-spacing: 0.1em;
    color: var(--color-gray-medium);
    // color: var(--color-rust);

    & a {
      color: var(--color-rust);
      text-decoration: none;
      transition: color 0.3s ease;

      &:hover,
      &:focus-visible {
        color: var(--color-bone);
      }
    }
  }

//   .colophon__dev-link {
//     color: inherit;
//     text-decoration: none;
//     transition: color 0.3s ease;

//     &:hover,
//     &:focus-visible {
//       color: var(--color-bone);
//     }
//   }

  .colophon__links {
    list-style: none;
    display: flex;
    justify-content: center;
    flex-wrap: wrap;
    gap: $spacing-md;

    a {
      font-family: $font-body;
      font-size: 0.9rem;
      color: var(--color-rust);
      text-decoration: none;
      letter-spacing: 0.05em;
      transition: color 0.3s ease;

      &:hover,
      &:focus-visible {
        color: var(--color-bone);
      }
    }
  }

  .colophon__sigils {
    display: flex;
    flex-wrap: wrap;
    align-items: center;
    justify-content: center;
    gap: $spacing-lg;
  }

  // Social links — conventional static/hover/active colouring (mirrors the spine nav).
  .colophon__social {
    position: relative;
    display: inline-flex;
    align-items: center;
    // Set --icon-size on the <a> (this component's scope) so it INHERITS into the
    // child <Icon> span. Setting it on .colophon__brand fails: that span carries the
    // Icon component's scope, not the footer's, so the footer rule never matches it.
    --icon-size: 24px;
    color: var(--color-rust); // static
    transition: color 0.3s ease;

    &:hover,
    &:focus-visible {
      color: var(--color-bone); // hover
    }

    &:active {
      color: var(--color-bone); // pressed
    }

    &:focus-visible {
      outline: 2px solid var(--color-bone);
      outline-offset: 6px;
      border-radius: 2px;
    }
  }

  // .colophon__brand icon size is inherited from .colophon__social's --icon-size (see note above).

  /* Sigil-reveal concept on hold — uncomment with the markup above to restore.
  .colophon__reveal {
    --icon-size: 40px;
    position: absolute;
    top: 50%;
    left: 50%;
    transform: translate(-50%, -50%);
    color: var(--color-rust);
    opacity: 0;
    pointer-events: none;
    transition: opacity 0.3s ease;
  }
  .colophon__social:hover .colophon__brand,
  .colophon__social:focus-visible .colophon__brand { opacity: 0; }
  .colophon__social:hover .colophon__reveal,
  .colophon__social:focus-visible .colophon__reveal { opacity: 1; }
  */
</style>
