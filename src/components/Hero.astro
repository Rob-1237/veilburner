---

<section class="hero">
  <!-- Background Image with Parallax -->
  <div
    class="hero__background"
    
  >
  </div>

  <!-- Content -->
  <div class="hero__content">
    <div class="hero__logo">
      <img src="/images/logo-entire-red-no-bg.png" alt="Veilburner" />
    </div>
    <p class="hero__tagline">AVANT-GARDE METAL</p>
  </div>
</section>

<style lang="scss">
  @import url("https://fonts.googleapis.com/css2?family=Cinzel:wght@400;700&family=Cormorant+Garamond:wght@400;700&family=Pirata+One&family=Metal+Mania&family=Creepster&family=Butcherman&family=Nosifer&family=Rubik+Mono+One&display=swap");
  @import "../styles/global.scss";

  .hero {
    position: relative;
    height: 100vh;
    display: flex;
    align-items: center;
    justify-content: center;
    // overflow: hidden;

    &::before {
      content: "";
      // position: absolute;
      // inset: 0;
      // background-image: url('/images/sigil-bg-1.png');
      // background-image: url('/images/key-bg-3.png');
      // height: 100vh;
      // background-size: 100% 100%;
      // background-size: cover;
      // background-position: bottom;
      // background-repeat: no-repeat;
      // opacity: 0.2;
      // z-index: 0;
    }

    @media (max-width: 768px) {
      // height: 70vh;
    }

    &__background {
      position: absolute;
      inset: 0;
      background-image: url('/images/both-members-9.jpg');
      background-size: cover;
      background-position: center center;
      background-repeat: no-repeat;
      // filter: grayscale(30%) contrast(120%) brightness(80%);

      @media (max-width: 768px) {
        background-image: url('/images/both-members-1.jpg');
        // background-size: 150%;
        background-position: center top;
        filter: grayscale(20%) contrast(110%) brightness(75%) sepia(20%);
      }

      &::before {
        content: "";
        position: absolute;
        inset: 0;
        background: linear-gradient(
          to top,
          rgba(0, 0, 0, 0.95) 0%,
          /* Very black at bottom */ rgba(0, 0, 0, 0.7) 10%,
          /* Still dark */ rgba(0, 0, 0, 0.3) 20%,
          /* Fading fast */ rgba(0, 0, 0, 0.05) 25%,
          /* Nearly transparent at 25% */ rgba(0, 0, 0, 0.05) 100%
            /* Stay subtle to top */
        );
        pointer-events: none;
        z-index: 1;

        @media (max-width: 768px) {
          // linear gradient here
        }
      }

      &::after {
        content: "";
        position: absolute;
        inset: 0;
        background: repeating-linear-gradient(
          0deg,
          rgba(0, 0, 0, 0.1) 0px,
          transparent 1px,
          transparent 2px,
          rgba(0, 0, 0, 0.1) 3px
        );
        pointer-events: none;
        z-index: 2;
      }
    }

    &__content {
      position: relative;
      z-index: 10;
      text-align: center;

      @media (max-width: 768px) {
        // max-width: 600px;
        top: 15vh;
      }
    }

    &__logo {
      max-width: 800px;
      width: 90%;
      margin: 0 auto;
      filter: drop-shadow(0 0 20px rgba(139, 0, 0, 0.5));

      img {
        width: 100%;
        height: auto;
        display: block;
      }

      @media (max-width: 768px) {
        max-width: 600px;
      }

      @media (max-width: 480px) {
        max-width: 400px;
      }
    }

    &__tagline {
      font-family: 'Cormorant Garamond', sans-serif;
      font-size: 1.5rem;
      font-weight: 600;
      margin-top: $spacing-md;
      color: $color-gray-light;
      letter-spacing: 0.2em;

      @media (max-width: 768px) {
        font-size: 1.25rem;
      }
    }
  }
</style>
