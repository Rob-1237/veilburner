---
// This would come from props in real use

---

<section class="hero">
  <!-- Background Image with Parallax -->
  <div class="hero__background">
    <div class="hero__bg-layer hero__bg-layer--1"></div>
    <div class="hero__bg-layer hero__bg-layer--2"></div>
  </div>

  <!-- Content -->
  <div class="hero__content">
    <!-- Logo overlay: mobile only (desktop bg has the logo baked in) -->
    <div class="hero__logo">
      <img src="/images/mobile-images/vb-logo-green.png" alt="Veilburner" />
    </div>
    <p class="hero__tagline">AVANT-GARDE METAL</p>
  </div>
</section>

<style lang="scss">
  @import "../styles/tokens";

  .hero {
    position: relative;
    height: 100vh;
    display: flex;
    align-items: center;
    justify-content: center;
    // overflow: hidden;

    &::before {
      content: "";
     
    }

    &__background {
      position: absolute;
      inset: 0;
      background-image: url('/images/home-page/home-bg-top.jpg');
      background-size: cover;
      background-position: center top;
      background-repeat: no-repeat;

      @media (max-width: 540px) {
        background-image: none; // Remove static background on mobile
      }

      &::before {
        content: "";
        position: absolute;
        inset: 0;
        background: linear-gradient(
          to top,
          rgba(0, 0, 0, 0.95) 0%,
          /* Very black at bottom */ rgba(0, 0, 0, 0.7) 10%,
          /* Still dark */ rgba(0, 0, 0, 0.3) 20%,
          /* Fading fast */ rgba(0, 0, 0, 0.05) 25%,
          /* Nearly transparent at 25% */ rgba(0, 0, 0, 0.05) 100%
            /* Stay subtle to top */
        );
        pointer-events: none;
        z-index: 3;
      }

      &::after {
        content: "";
        position: absolute;
        inset: 0;
        background: repeating-linear-gradient(
          0deg,
          rgba(0, 0, 0, 0.1) 0px,
          transparent 1px,
          transparent 2px,
          rgba(0, 0, 0, 0.1) 3px
        );
        pointer-events: none;
        z-index: 4;
      }
    }

    &__bg-layer {
      display: none; // Hidden on desktop

      @media (max-width: 768px) {
        display: block;
        position: absolute;
        inset: 0;
        background-size: cover;
        background-position: center;
        // background-position: center top;
        background-repeat: no-repeat;
        filter: grayscale(20%) contrast(110%) brightness(75%) sepia(20%);
      }

      &--1 {
        @media (max-width: 540px) {
          background-image: url('/images/mobile-images/mobile-home-top-1.jpg');
          animation: deckShuffle 60s ease infinite;
          animation-delay: 0s;
          z-index: 2;
          opacity: 1;
        }
      }

      &--2 {
        @media (max-width: 540px) {
          background-image: url('/images/mobile-images/mobile-home-top-2.jpg');
          animation: deckShuffle 60s ease infinite;
          animation-delay: 30s;
          z-index: 1;
          opacity: 1;
        }
      }
    }

    @keyframes deckShuffle {
      0% {
        z-index: 2;
        opacity: 1;
      }
      21% { // 25s - stay visible on top
        z-index: 2;
        opacity: 1;
      }
      29% { // 35s - fade out (ease-in for 10s)
        z-index: 2;
        opacity: 0;
        animation-timing-function: ease-in;
      }
      33% { // 40s - swap to back while invisible
        z-index: 1;
        opacity: 0;
      }
      42% { // 50s - fade in behind (ease-in-out for 10s)
        z-index: 1;
        opacity: 1;
        animation-timing-function: ease-in-out;
      }
      46% { // 55s - stay visible behind
        z-index: 1;
        opacity: 1;
      }
      71% { // 85s - stay visible behind
        z-index: 1;
        opacity: 1;
      }
      79% { // 95s - fade out behind (ease-in for 10s)
        z-index: 1;
        animation-timing-function: ease-in;
      }
      83% { // 100s - swap to front while invisible
        z-index: 2;
      }
      92% { // 110s - fade in on top (ease-in-out for 10s)
        z-index: 2;
        opacity: 1;
        animation-timing-function: ease-in-out;
      }
      100% { // 120s - loop
        z-index: 2;
        opacity: 1;
      }
    }

    &__content {
      position: relative;
      z-index: 10;
      text-align: center;

      @media (max-width: 768px) {
        top: 15vh;
      }
    }

    // Green VB logo — shown only on mobile, where the deck-shuffle
    // background images don't carry the logo (desktop bg does).
    &__logo {
      display: none;

      @media (max-width: 540px) {
        display: block;
        width: 70%;
        max-width: 360px;
        margin: 0 auto;
        filter: drop-shadow(0 0 20px rgba(56, 91, 56, 0.5));

        img {
          width: 100%;
          height: auto;
          display: block;
        }
      }
    }

    &__tagline {
      font-family: $font-sub;
      font-size: 1.5rem;
      font-weight: 600;
      margin-top: $spacing-md;
      color: $color-gray-light;
      letter-spacing: 0.2em;

      @media (max-width: 768px) {
        font-size: 1.25rem;
      }
    }
  }
</style>
