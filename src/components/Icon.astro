---
// Inline SVG icon. Reads the optimized source in src/icons/<name>.svg (all use
// fill="currentColor") and inlines it, so ONE file serves every state — colour,
// hover, and active are controlled entirely by CSS `color` on an ancestor.
//
//   <Icon name="home" size={30} />           decorative (aria-hidden)
//   <Icon name="listen" title="Listen" />    labelled (role="img")
const icons = import.meta.glob('../icons/*.svg', {
  query: '?raw',
  import: 'default',
  eager: true,
}) as Record<string, string>;

export interface Props {
  name: string;
  class?: string;
  /** Rendered box size in px (icons scale to fill it). Omit to inherit `1em`. */
  size?: number;
  /** Accessible label. If omitted, the icon is treated as decorative. */
  title?: string;
}

const { name, class: className, size, title } = Astro.props;
const key = `../icons/${name}.svg`;
const raw = icons[key];
if (!raw) {
  throw new Error(
    `<Icon name="${name}"> not found. Expected src/icons/${name}.svg. ` +
      `Available: ${Object.keys(icons).map((k) => k.replace('../icons/', '').replace('.svg', '')).join(', ')}`,
  );
}
const style = size ? `--icon-size:${size}px` : undefined;
---

<span
  class:list={['icon', className]}
  style={style}
  role={title ? 'img' : undefined}
  aria-label={title}
  aria-hidden={title ? undefined : 'true'}
  set:html={raw}
/>

<style>
  .icon {
    display: inline-flex;
    width: var(--icon-size, 1em);
    height: var(--icon-size, 1em);
    color: inherit;
    line-height: 0;
  }
  .icon :global(svg) {
    width: 100%;
    height: 100%;
    display: block;
    fill: currentColor;
  }
</style>
