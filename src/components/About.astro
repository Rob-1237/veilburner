---
// In real app, this would come from data/band-info.json or CMS
const bandInfo = {
  bio: "Veilburner is a two-man metal project that emerged from the underground with a sound that eludes classification. Their strain of avant-garde metal has carved a unique path through the extreme music landscape.\n\nComprised of Mephisto Deleterio (David Moody) and Chrisom Infernium (Chris Sheppard), the duo has released eight full-length albums since 2014. Their boundary-pushing approach to songwriting and relentless experimentation have earned them a dedicated cult following within the global metal scene.\n\nVeilburner's music delves into themes of occult mysticism, cosmic horror, and esoteric philosophy, channeled through dissonant riffs, atmospheric layers, and visceral vocal performances that pull metal toward a beautifully nightmarish terrain.",
  formed: "2014",
  location: "Pennsylvania, USA",
  genre: "Avant-Garde Black/Death Metal",
  label: "Transcending Obscurity Records",
  image: "/images/both-members-3.jpg"
};

// FONT TESTING: Toggle one at a time by uncommenting
// const testBioFont = "Inter";
// const testBioFont = "Source Code Pro";
const testBioFont = "IBM Plex Mono";
// const testBioFont = "Inconsolata";
// const testBioFont = "Courier Prime";
---

<section class="about">
  <div class="container">
    <!-- <h2 class="about__title">ABOUT</h2> -->

    <div class="about__content">
      <div class="about__image-wrapper">
        <div class="about__image">
          <img src={bandInfo.image} alt="Band photo" class="scroll-reveal-image" />
          <img src={bandInfo.image} alt="" class="scroll-reveal-image-inverted" aria-hidden="true" />
        </div>
        <!-- <div class="about__logo">
          <img src="/images/logo-vb-white-no-bg.png" alt="Veilburner logo" />
        </div> -->
      </div>

      <div class="about__text">
        <div class="about__bio" style={`font-family: '${testBioFont}', monospace;`}>
          {bandInfo.bio.split('\n\n').map((paragraph) => (
            <p>{paragraph}</p>
          ))}
        </div>

        <div class="about__details">
          <div class="about__detail">
            <span class="about__detail-label">Formed</span>
            <span class="about__detail-value">{bandInfo.formed}</span>
          </div>
          <div class="about__detail">
            <span class="about__detail-label">Location</span>
            <span class="about__detail-value">{bandInfo.location}</span>
          </div>
          <div class="about__detail">
            <span class="about__detail-label">Genre</span>
            <span class="about__detail-value">{bandInfo.genre}</span>
          </div>
          <div class="about__detail">
            <span class="about__detail-label">Label</span>
            <span class="about__detail-value">{bandInfo.label}</span>
          </div>
        </div>
      </div>
    </div>
  </div>
</section>

<style lang="scss">
  @import url('https://fonts.googleapis.com/css2?family=Source+Code+Pro:wght@400;700&family=IBM+Plex+Mono:wght@400;700&family=Inconsolata:wght@400;700&family=Courier+Prime:wght@400;700&display=swap');
  @import '../styles/global.scss';

  .about {
    padding: $spacing-3xl $spacing-md;

    &__title {
      font-family: $font-metal;
      font-size: 4rem;
      margin-bottom: $spacing-2xl;
      text-align: center;

      @media (max-width: 768px) {
        font-size: 3rem;
      }
    }

    &__content {
      max-width: 1200px;
      margin: 0 auto;
      display: grid;
      grid-template-columns: 1fr 2fr;
      gap: $spacing-2xl;

      @media (max-width: 968px) {
        grid-template-columns: 1fr;
        gap: $spacing-xl;
      }
    }

    &__image-wrapper {
      position: relative;
      display: flex;
      flex-direction: column;
      gap: $spacing-lg;
    }

    &__image {
      position: relative;
      width: 100%;
      clip-path: polygon(20px 0, 100% 0, 100% calc(100% - 20px), calc(100% - 20px) 100%, 0 100%, 0 20px);
      border: 3px solid $color-blood-solid;
      overflow: hidden;

      img {
        width: 100%;
        height: auto;
        display: block;

        // Base image (normal)
        &.scroll-reveal-image {
          filter: grayscale(40%) contrast(115%);
          transition: opacity 0.3s ease-out;
          position: relative;
          z-index: 2;
        }

        // Inverted sepia clone (underneath)
        &.scroll-reveal-image-inverted {
          position: absolute;
          top: 0;
          left: 0;
          filter: invert(1) sepia(0.8) hue-rotate(20deg) contrast(115%);
          opacity: 0;
          pointer-events: none;
          z-index: 1;
        }
      }
    }

    &__logo {
      width: 100%;
      max-width: 200px;
      margin: 0 auto;

      img {
        width: 100%;
        height: auto;
        display: block;
        filter: drop-shadow(0 0 10px rgba(139, 115, 85, 0.3));
      }
    }

    &__text {
      display: flex;
      flex-direction: column;
      gap: $spacing-xl;
    }

    &__bio {
      p {
        margin-bottom: $spacing-md;
        line-height: 1.8;
        color: $color-gray-light;

        &:last-child {
          margin-bottom: 0;
        }
      }
    }

    &__details {
      display: grid;
      grid-template-columns: repeat(2, 1fr);
      gap: $spacing-md;
      padding-top: $spacing-lg;
      border-top: 2px solid $color-rust;

      @media (max-width: 568px) {
        grid-template-columns: 1fr;
      }
    }

    &__detail {
      display: flex;
      flex-direction: column;
      gap: $spacing-xs;
    }

    &__detail-label {
      font-size: 0.8rem;
      color: $color-gray-medium;
      text-transform: uppercase;
      letter-spacing: 0.1em;
    }

    &__detail-value {
      font-family: $font-metal;
      font-size: 1.1rem;
      color: $color-rust;
      letter-spacing: 0.05em;
    }
  }
</style>

<script>
  // Proximity-based opacity crossfade between normal and inverted
  function initProximityEffect() {
    const normalImage = document.querySelector('.scroll-reveal-image');
    const invertedImage = document.querySelector('.scroll-reveal-image-inverted');
    if (!normalImage || !invertedImage) return;

    function updateOpacity() {
      const rect = normalImage.getBoundingClientRect();
      const imageCenterY = rect.top + rect.height / 2;
      const viewportCenterY = window.innerHeight / 2;

      // Distance from viewport center (in pixels)
      const distance = Math.abs(imageCenterY - viewportCenterY);

      // Normalize distance to 0-1 range (0 = centered, 1 = fully off-center)
      const normalizedDistance = Math.min(distance / (window.innerHeight / 2), 1);

      // Crossfade:
      // - normalizedDistance 0 (centered) = normal image visible, inverted hidden
      // - normalizedDistance 1 (off-center) = normal image faded, inverted visible
      normalImage.style.opacity = (1 - normalizedDistance).toString();
      invertedImage.style.opacity = normalizedDistance.toString();
    }

    // Update on scroll
    let ticking = false;
    window.addEventListener('scroll', () => {
      if (!ticking) {
        window.requestAnimationFrame(() => {
          updateOpacity();
          ticking = false;
        });
        ticking = true;
      }
    });

    // Initial update
    updateOpacity();
  }

  // Initialize on page load
  document.addEventListener('DOMContentLoaded', initProximityEffect);

  // Re-initialize after page transitions
  document.addEventListener('astro:after-swap', initProximityEffect);
</script>
