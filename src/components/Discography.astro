---
import { albums } from '../data/albums.js';
---

<h1 class="discography__title">DISCOGRAPHY</h1>
<section class="discography">
  <div class="container">

    <div class="discography__grid">
      {albums.map((album) => (
        <article class="album-card">
          <a href={`/listen/${album.slug}`} class="album-card__link">
            <div class="album-card__cover">
              <img src={album.cover} alt={`${album.title} album cover`} />
              <div class="album-card__overlay">
                <svg class="album-card__cta" viewBox="0 0 24 24" fill="none" xmlns="http://www.w3.org/2000/svg">
                  <path d="M8 5v14l11-7L8 5z" fill="currentColor"/>
                </svg>
              </div>
            </div>
            <div class="album-card__info">
              <h3 class="album-card__title">{album.title}</h3>
              <p class="album-card__year">{album.year}</p>
            </div>
          </a>
        </article>
      ))}
    </div>
  </div>
</section>

<style lang="scss">
  @import '../styles/global.scss';

  .discography {
    padding: $spacing-3xl $spacing-md;
    background: linear-gradient(180deg, $color-void 0%, $color-gray-dark 50%, $color-void 100%);

    &__title {
      // font-family: $font-sub;
      // font-size: 4rem;
      // margin-bottom: $spacing-2xl;
      // text-align: center;
      padding: 0;
      font-family: $font-sub;
      font-size: 3rem;
      text-align: center;
      margin-top: 8rem;
      text-transform: uppercase;
      letter-spacing: 0.15em;
      font-weight: 300;


      @media (max-width: 768px) {
        font-size: 3rem;
      }
    }

    &__grid {
      display: grid;
      grid-template-columns: repeat(auto-fit, minmax(280px, 1fr));
      gap: $spacing-xl;
      max-width: 1200px;
      margin: 0 auto;

      @media (max-width: 768px) {
        grid-template-columns: repeat(auto-fit, minmax(240px, 1fr));
        gap: $spacing-lg;
      }
    }
  }

  .album-card {
    position: relative;

    &__link {
      display: block;
      text-decoration: none;
      color: inherit;
    }

    &__cover {
      position: relative;
      width: 100%;
      padding-bottom: 100%; // Square aspect ratio
      overflow: hidden;
      border: 2px solid $color-blood;
      clip-path: polygon(12px 0, 100% 0, 100% calc(100% - 12px), calc(100% - 12px) 100%, 0 100%, 0 12px);
      background: $color-gray-dark;

      img {
        position: absolute;
        top: 0;
        left: 0;
        width: 100%;
        height: 100%;
        object-fit: cover;
        filter: grayscale(20%) contrast(110%);
        transition: all 0.4s ease;
      }
    }

    &__overlay {
      position: absolute;
      inset: 0;
      background: rgba(90, 58, 42, 0.95);
      display: flex;
      align-items: center;
      justify-content: center;
      opacity: 0;
      transition: opacity 0.4s ease;
    }

    &__cta {
      width: 8rem;
      height: 8rem;
      color: $color-white;
      transform: translateY(10px);
      transition: transform 0.4s ease;
    }

    &__info {
      margin-top: $spacing-sm;
    }

    &__title {
      font-family: $font-metal;
      font-size: 1.25rem;
      text-transform: uppercase;
      letter-spacing: 0.1em;
      margin-bottom: $spacing-xs;
    }

    &__year {
      color: $color-gray-medium;
      font-size: 0.9rem;
      letter-spacing: 0.05em;
    }

    &:hover {
      .album-card__cover img {
        transform: scale(1.05);
        filter: grayscale(0%) contrast(120%);
      }

      .album-card__overlay {
        opacity: .6;
      }

      .album-card__cta {
        transform: translateY(0);
      }
    }
  }
</style>
