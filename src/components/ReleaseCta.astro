---
// The two release CTAs: Hear (Bandcamp) and Buy (Transcending Obscurity),
// each carrying the same icon used in the footer for consistency.
// Pass `floating` to pin it to the bottom-right of the viewport (About/Listen/Archive).
import Icon from './Icon.astro';

interface Props {
  floating?: boolean;
}
const { floating = false } = Astro.props;

const bandcamp = 'https://veilburnerband.bandcamp.com/album/all-that-glimmers-is-gloam';
const label = 'https://tometal.com/?s=veilburner';
---

<div class:list={['release-cta', { 'release-cta--floating': floating }]}>
  <a href={bandcamp} target="_blank" rel="noopener noreferrer" class="btn release-cta__btn" aria-label="Hear on Bandcamp">
    <span>Hear</span>
    <span class="release-cta__dot" aria-hidden="true">&middot;</span>
    <Icon name="bandcamp" class="release-cta__icon" />
  </a>
  <a href={label} target="_blank" rel="noopener noreferrer" class="btn release-cta__btn" aria-label="Buy from Transcending Obscurity">
    <span>Buy</span>
    <span class="release-cta__dot" aria-hidden="true">&middot;</span>
    <Icon name="vinyl" class="release-cta__icon" />
  </a>
</div>

<style lang="scss">
  @import '../styles/tokens';

  .release-cta {
    display: flex;
    flex-wrap: wrap;
    justify-content: flex-end;
    gap: 0.75rem;

    &--floating {
      position: fixed;
      bottom: 1.5rem;
      right: 1.5rem;
      z-index: 9000;

      @media (max-width: 768px) {
        bottom: 1rem;
        right: 1rem;
        gap: 0.5rem;
      }
    }
  }

  .release-cta__btn {
    display: inline-flex;
    align-items: center;
    gap: 0.5rem;
    font-size: 0.72rem;
    padding: 0.6rem 1.1rem;
    // Icon size set on the <a> so it inherits into the child <Icon> span.
    --icon-size: 1.25em;

    @media (max-width: 768px) {
      font-size: 0.62rem;
      padding: 0.5rem 0.85rem;
    }
  }

  .release-cta__dot {
    opacity: 0.65;
  }
</style>
