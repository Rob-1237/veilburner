---
// Latest / upcoming release feature (shown at the foot of the Home page).
// NOTE: "Contact" is a legacy name — this holds no contact info. Slated to be
// renamed <ReleaseFeature> and folded into index.astro in Phase 3.
---

<section class="contact">
  <img src="/images/home-page/home-bg-bottom.jpg" alt="Veilburner" />

  <div class="album-overlay">
    <a
      href="https://veilburnerband.bandcamp.com/album/all-that-glimmers-is-gloam"
      target="_blank"
      rel="noopener noreferrer"
      class="album-overlay__art-link"
      aria-label="All That Glimmers Is Gloam on Bandcamp"
    >
      <img src="/images/album-art/album-art-2026.jpg" alt="All That Glimmers Is Gloam album cover" class="album-overlay__art" />
    </a>
    <div class="album-overlay__text">
      <p class="album-overlay__new">Their upcoming release</p>
      <p class="album-overlay__title">All That Glimmers is Gloam</p>
      <p class="album-overlay__release">Out 10/16/26 on <a href="https://tometal.com/?s=veilburner" target="_blank" rel="noopener noreferrer" class="album-overlay__label-link">Transcending Obscurity Records</a></p>
    </div>
  </div>
</section>

<style lang="scss">
  @import "../styles/tokens";

  .contact {
    padding: 0;
    margin: 0;
    width: 100%;
    position: relative;

    > img {
      width: 100%;
      height: auto;
      display: block;
    }
  }

  .album-overlay {
    position: absolute;
    bottom: 2rem;
    left: 2rem;
    display: flex;
    align-items: flex-end;
    gap: 1.5rem;
    z-index: 10;

    @media (max-width: 768px) {
      bottom: .5rem;
      left: .5rem;
      align-items: flex-end;
    }

    &__art-link {
      display: block;
      flex-shrink: 0;
      transition: transform 0.3s ease;
    }

    &__art {
      width: 15vw;
      height: auto;
      display: block;
      border: 2px solid $color-blood-solid;
      clip-path: polygon(12px 0, 100% 0, 100% calc(100% - 12px), calc(100% - 12px) 100%, 0 100%, 0 12px);

      @media (max-width: 768px) {
        width: 20vw;
        border: 1px solid $color-blood-solid;
      }
    }

    &__text {
      display: flex;
      flex-direction: column;
      justify-content: flex-end;

      @media (max-width: 768px) {
        max-width: 350px;
      }

      p {
        margin: 0;
      }
    }

    &__new {
      font-family: $font-body;
      font-size: 0.9rem;
      color: var(--color-gray-medium);
      letter-spacing: 0.1em;
      line-height: 1.4;
      font-weight: 300;

      @media (max-width: 768px) {
        font-size: 0.6rem;
      }
    }

    &__title {
      font-family: $font-sub;
      font-size: 1.25rem;
      color: $color-gray-light;
      letter-spacing: 0.1em;
      text-transform: none;
      display: block;
      margin-top: 0.25rem;

      @media (max-width: 768px) {
        font-size: .9rem;
      }
    }

    &__release {
      font-family: $font-body;
      font-size: 0.9rem;
      color: var(--color-gray-medium);
      letter-spacing: 0.1em;
      line-height: 1.4;
      font-weight: 300;

      @media (max-width: 768px) {
        font-size: 0.6rem;
      }
    }

    &__label-link {
      color: var(--color-gray-medium);
      text-decoration: none;
      transition: color 0.3s ease;

      &:hover {
        color: $color-bone;
      }
    }
  }
</style>
